<%- include("partials/layout-open", { pageTitle: "HR Review Application", activePortal: "hr" }) %>
<main class="container">
      <section class="card">
        <div class="row-between">
          <h1>HR Review Application</h1>
          <div class="actions tight">
            <a class="btn secondary" href="/hr/departments">Department Review</a>
            <a class="btn secondary" href="/hr/communications">Communications</a>
            <a class="btn secondary" href="/hr/reports">Reports</a>
            <a class="btn secondary" href="/hr/admin-accounts">Admin Accounts</a>
            <a class="btn secondary" href="/hr/account">HR Account</a>
            <a class="btn secondary" href="/hr/periods">Period and Slot Settings</a>
            <a class="btn secondary" href="/hr/applications">Back to HR Queue</a>
            <form action="/hr/logout" method="post">
              <button class="btn secondary" type="submit">Logout</button>
            </form>
          </div>
        </div>

        <% if (error) { %>
          <div class="alert"><%= error %></div>
        <% } %>

        <% if (notice) { %>
          <div class="notice"><%= notice %></div>
        <% } %>

        <% if (application.isFrozen) { %>
          <div class="alert">
            This application record is frozen under department review. Restore it there before
            continuing the HR workflow.
          </div>
        <% } %>

        <div class="summary">
          <p><strong>ID:</strong> <%= application.id %></p>
          <p><strong>Tracking / Placement Number:</strong> <%= application.placementNumber || application.id %></p>
          <p><strong>Name:</strong> <%= application.fullName %></p>
          <p><strong>Email:</strong> <%= application.email %></p>
          <p><strong>Phone:</strong> <%= application.phone %></p>
          <p><strong>Institution:</strong> <%= application.institution %></p>
          <p><strong>Course:</strong> <%= application.course %></p>
          <p><strong>Applied Department:</strong> <%= application.appliedDepartment ? getDepartmentLabel(application.appliedDepartment) : 'Not set' %></p>
          <p><strong>Assigned Department:</strong> <%= application.assignedDepartment ? getDepartmentLabel(application.assignedDepartment) : 'Not assigned' %></p>
          <p><strong>Period:</strong> <%= application.period ? getPeriodLabel(application.period) : 'Not set' %></p>
          <p><strong>Requested Dates:</strong> <%= application.startDate %> to <%= application.endDate %></p>
          <p><strong>Status:</strong> <span class="badge <%= getStatusClass(application.status) %>"><%= application.status %></span></p>
          <p><strong>Record State:</strong> <%= application.isFrozen ? 'Frozen' : 'Active' %></p>
          <p><strong>Submitted:</strong> <%= formatDate(application.submittedAt) %></p>
          <p><strong>Terms Accepted:</strong> <%= application.termsAcceptance && application.termsAcceptance.agreed ? `Yes - ${formatDate(application.termsAcceptance.agreedAt)}` : 'Not recorded' %></p>
          <p><strong>Recorded Source:</strong> <%= application.termsAcceptance && application.termsAcceptance.ipAddress ? application.termsAcceptance.ipAddress : 'Not recorded' %></p>
          <p><strong>Terms Version:</strong> <%= application.termsAcceptance && application.termsAcceptance.version ? application.termsAcceptance.version : 'Not recorded' %></p>
          <p><strong>Last Updated:</strong> <%= formatDate(application.updatedAt) %></p>
          <p><strong>NITA Workflow:</strong> <%= application.nitaWorkflow.status %></p>
          <p><strong>Department/HR Comment:</strong> <%= application.reviewerComment || 'No comment yet.' %></p>
        </div>

        <h2>Submitted Documents</h2>
        <% if (application.combinedDocument && application.combinedDocument.filename) { %>
          <ul>
            <li>
              <a href="/hr/files/<%= application.combinedDocument.filename %>" target="_blank"><%= combinedDocumentDefinition.label %></a>
              <% const combinedSecurity = application.combinedDocument.security || (application.documentSecurity && application.documentSecurity[combinedDocumentDefinition.key]); %>
              <% if (combinedSecurity) { %>
                <small>
                  (Scan: passed, type: <%= combinedSecurity.detectedType %>,
                  size: <%= combinedSecurity.size %> bytes)
                </small>
              <% } %>
            </li>
            <li>
              <% if (application.nitaDocument && application.nitaDocument.filename) { %>
                <a href="/hr/files/<%= application.nitaDocument.filename %>" target="_blank"><%= nitaDocumentDefinition.label %></a>
                <% const nitaSecurity = application.nitaDocument.security || (application.documentSecurity && application.documentSecurity[nitaDocumentDefinition.key]); %>
                <% if (nitaSecurity) { %>
                  <small>
                    (Scan: passed, type: <%= nitaSecurity.detectedType %>,
                    size: <%= nitaSecurity.size %> bytes)
                  </small>
                <% } %>
              <% } else { %>
                <span><%= nitaDocumentDefinition.label %> - Not uploaded</span>
              <% } %>
            </li>
          </ul>
        <% } else { %>
          <p>No combined document uploaded.</p>
        <% } %>

        <h2>NITA Workflow</h2>
        <p>The system generates the county-endorsed NITA document automatically after the student uploads the initial NITA file. HR only waits for the stamped return copy, then confirms the NITA stage before the final admission decision.</p>

        <div class="summary">
          <p><strong>Initial NITA document:</strong>
            <%= application.nitaDocument && application.nitaDocument.filename ? 'Submitted' : 'Not uploaded' %>
          </p>
          <p><strong>County-endorsed NITA document:</strong>
            <%= application.countySignedNitaDocument && application.countySignedNitaDocument.filename ? 'Generated automatically' : 'Not generated yet' %>
          </p>
          <p><strong>Stamped NITA re-submission:</strong>
            <%= application.nitaResubmittedDocument && application.nitaResubmittedDocument.filename ? 'Received from student' : 'Not received yet' %>
          </p>
          <p><strong>Workflow note:</strong> <%= application.nitaWorkflow.comment || 'No NITA workflow note yet.' %></p>
        </div>

        <% if (application.countySignedNitaDocument && application.countySignedNitaDocument.filename) { %>
          <div class="actions tight">
            <a class="btn secondary" href="/hr/files/<%= application.countySignedNitaDocument.filename %>" target="_blank">Download County-Endorsed NITA</a>
          </div>
        <% } %>

        <% if (application.nitaResubmittedDocument && application.nitaResubmittedDocument.filename) { %>
          <div class="summary">
            <p><strong>Student returned stamped NITA document:</strong></p>
            <div class="actions tight">
              <a class="btn secondary" href="/hr/files/<%= application.nitaResubmittedDocument.filename %>" target="_blank">Download Stamped NITA Re-Submission</a>
            </div>
          </div>
        <% } %>

        <% if (application.nitaWorkflow.status !== 'Completed' && application.nitaResubmittedDocument && application.nitaResubmittedDocument.filename) { %>
          <form action="/hr/applications/<%= application.id %>/nita-complete" method="post" class="form-grid">
            <div class="actions full-width">
              <button class="btn" type="submit">Confirm NITA Workflow Complete</button>
            </div>
          </form>
        <% } %>

        <h2>HR Final Decision</h2>
        <p>Department review happens first. HR can only make the final admission decision after the NITA workflow is completed.</p>
        <form action="/hr/applications/<%= application.id %>/status" method="post" class="form-grid">
          <label>
            HR Status
            <select name="status" required>
              <% hrStatusOptions.forEach((status) => { %>
                <% const approvalLocked = status === 'Admitted' && application.nitaWorkflow.status !== 'Completed' && application.status !== 'Admitted'; %>
                <option value="<%= status %>" <%= application.status === status ? 'selected' : '' %> <%= approvalLocked ? 'disabled' : '' %>><%= status %></option>
              <% }) %>
            </select>
            <% if (application.nitaWorkflow.status !== 'Completed') { %>
              <span class="field-hint">Final admission stays locked until HR confirms the stamped NITA document.</span>
            <% } %>
          </label>

          <label class="full-width">
            HR Comment
            <textarea name="reviewerComment" rows="4" placeholder="Decision notes"><%= application.reviewerComment %></textarea>
          </label>

          <div class="actions full-width">
            <button class="btn" type="submit">Save HR Decision</button>
          </div>
        </form>

        <h2>Student Communication History</h2>
        <p>General HR broadcasts and workflow-triggered notifications for this student appear below. Use the main HR Communications page to send updates to all applicant contacts.</p>
        <div class="summary">
          <p><strong>Email alerts:</strong> <%= notificationProviderSummary.emailEnabled ? 'Configured' : 'Not configured' %></p>
          <p><strong>SMS alerts:</strong> <%= notificationProviderSummary.smsEnabled ? 'Configured' : 'Not configured' %></p>
          <div class="actions tight">
            <a class="btn secondary" href="/hr/communications">Open HR Communications</a>
          </div>
        </div>

        <details class="history-toggle">
          <summary>
            Communication History
            <span class="history-toggle-meta">
              <%= application.notificationHistory && application.notificationHistory.length ? `${application.notificationHistory.length} entries` : 'No entries yet' %>
            </span>
          </summary>

          <% if (application.notificationHistory && application.notificationHistory.length) { %>
            <div class="task-list">
              <% application.notificationHistory.slice(0, 12).forEach((entry) => { %>
                <div class="summary">
                  <p>
                    <strong><%= entry.channel.toUpperCase() %></strong>
                    <span class="badge <%= entry.status === 'sent' ? 'verified' : entry.status === 'failed' ? 'rejected' : 'pending' %>"><%= entry.status %></span>
                  </p>
                  <p><strong>Event:</strong> <%= entry.eventType || 'manual' %></p>
                  <% if (entry.subject) { %>
                    <p><strong>Subject:</strong> <%= entry.subject %></p>
                  <% } %>
                  <p><strong>Message:</strong> <%= entry.message %></p>
                  <p><strong>Recipient:</strong> <%= entry.recipient || 'Not available' %></p>
                  <p><strong>Sent:</strong> <%= formatDate(entry.sentAt) %></p>
                  <% if (entry.reason) { %>
                    <p><strong>Provider note:</strong> <%= entry.reason %></p>
                  <% } %>
                </div>
              <% }) %>
            </div>
          <% } else { %>
            <p>No communication history recorded yet.</p>
          <% } %>
        </details>

        <h2>Joining Letter Upload (HR Only)</h2>
        <p>Complete the NITA workflow and set status to <strong>Admitted</strong> first, then upload the joining letter.</p>
        <form action="/hr/applications/<%= application.id %>/joining-letter" method="post" enctype="multipart/form-data" class="form-grid">
          <label class="full-width">
            Joining Letter (PDF only)
            <input type="file" name="joiningLetter" accept=".pdf,application/pdf" required />
          </label>
          <div class="actions full-width">
            <button class="btn" type="submit">Upload Joining Letter</button>
          </div>
        </form>

        <% if (application.joiningLetter && application.joiningLetter.filename) { %>
          <div class="actions">
            <a class="btn secondary" href="/hr/files/<%= application.joiningLetter.filename %>" target="_blank">Download Current Joining Letter</a>
          </div>
        <% } %>
      </section>
    </main>
<%- include("partials/layout-close") %>


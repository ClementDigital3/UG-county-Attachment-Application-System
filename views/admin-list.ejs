<%- include("partials/layout-open", { pageTitle: "Department Review Queue", activePortal: "hr" }) %>
<main class="container wide">
      <section class="card">
        <div class="row-between">
          <h1>Department Review Queue</h1>
          <div class="actions tight">
            <a class="btn secondary" href="/hr/applications">HR Queue</a>
            <a class="btn secondary" href="/hr/departments">Department Access</a>
            <a class="btn secondary" href="/admin/reports">Department Report</a>
            <a class="btn secondary" href="/hr/periods">Period and Slot Settings</a>
            <form action="/hr/logout" method="post">
              <button class="btn secondary" type="submit">Logout</button>
            </form>
          </div>
        </div>

        <% if (adminScopeDepartmentLabel) { %>
          <p><strong>HR Department Review Scope:</strong> <%= adminScopeDepartmentLabel %></p>
        <% } %>

        <div class="stats compact">
          <div>
            <strong><%= stats.total %></strong>
            <span>Total</span>
          </div>
          <div>
            <strong><%= stats.pending %></strong>
            <span>Pending</span>
          </div>
          <div>
            <strong><%= stats.needsCorrection %></strong>
            <span>Needs Correction</span>
          </div>
          <div>
            <strong><%= stats.verified %></strong>
            <span>Verified</span>
          </div>
          <div>
            <strong><%= stats.approved %></strong>
            <span>Admitted</span>
          </div>
          <div>
            <strong><%= stats.rejected %></strong>
            <span>Rejected</span>
          </div>
        </div>

        <form method="get" action="/admin/applications" class="filter-row">
          <label>
            Filter by status
            <select name="status">
              <option value="All" <%= statusFilter === 'All' ? 'selected' : '' %>>All</option>
              <option value="Pending" <%= statusFilter === 'Pending' ? 'selected' : '' %>>Pending</option>
              <option value="Needs Correction" <%= statusFilter === 'Needs Correction' ? 'selected' : '' %>>Needs Correction</option>
              <option value="Verified" <%= statusFilter === 'Verified' ? 'selected' : '' %>>Verified</option>
              <option value="Admitted" <%= statusFilter === 'Admitted' ? 'selected' : '' %>>Admitted</option>
              <option value="Rejected" <%= statusFilter === 'Rejected' ? 'selected' : '' %>>Rejected</option>
            </select>
          </label>
          <input type="hidden" name="department" value="<%= departmentFilter %>" />
          <button class="btn" type="submit">Apply Filter</button>
        </form>

        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th class="table-number-cell">ID</th>
                <th>Tracking Number</th>
                <th>Name</th>
                <th>Email</th>
                <th>Institution</th>
                <th>Applied Department</th>
                <th>Period</th>
                <th class="table-status-cell">Status</th>
                <th class="table-date-cell">Submitted</th>
                <th class="table-action-cell">Action</th>
              </tr>
            </thead>
            <tbody>
              <% if (!applications.length) { %>
                <tr>
                  <td class="table-empty-state" colspan="10"><strong>No applications found.</strong> Adjust the selected filter and try again.</td>
                </tr>
              <% } %>

              <% applications.forEach((application) => { %>
                <tr>
                  <td class="table-number-cell"><%= application.id %></td>
                  <td><%= application.placementNumber || application.id %></td>
                  <td><%= application.fullName %></td>
                  <td><%= application.email %></td>
                  <td><%= application.institution %></td>
                  <td><%= application.appliedDepartment ? getDepartmentLabel(application.appliedDepartment) : 'Not set' %></td>
                  <td><%= application.period ? getPeriodLabel(application.period) : 'Not set' %></td>
                  <td class="table-status-cell">
                    <span class="badge <%= getStatusClass(application.status) %>"><%= application.status %></span>
                    <% if (application.isFrozen) { %>
                      <span class="badge rejected">Frozen</span>
                    <% } %>
                  </td>
                  <td class="table-date-cell"><%= formatDate(application.submittedAt) %></td>
                  <td class="table-action-cell">
                    <div class="table-actions">
                      <a href="/admin/applications/<%= application.id %>">Review</a>
                      <% if (application.isFrozen) { %>
                        <form action="/admin/applications/<%= application.id %>/unfreeze" method="post">
                          <button type="submit" class="link-btn">Restore</button>
                        </form>
                      <% } else { %>
                        <form action="/admin/applications/<%= application.id %>/freeze" method="post" onsubmit="return confirm('Freeze this application record?');">
                          <button type="submit" class="link-btn danger-text">Freeze</button>
                        </form>
                      <% } %>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>
    </main>
<%- include("partials/layout-close") %>

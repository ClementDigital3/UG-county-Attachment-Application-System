<%- include("partials/layout-open", { pageTitle: "Admin Dashboard", activePortal: "admin" }) %>
<main class="container wide">
      <section class="card">
        <div class="row-between">
          <h1>Applications Dashboard</h1>
          <div class="actions tight">
            <a class="btn secondary" href="/admin/reports">Reports</a>
            <a class="btn secondary" href="/admin/departments">Departments</a>
            <a class="btn secondary" href="/admin/periods">Periods and Slots</a>
            <form action="/admin/logout" method="post">
              <button class="btn secondary" type="submit">Logout</button>
            </form>
          </div>
        </div>

        <% if (adminScopeDepartmentLabel) { %>
          <p><strong>Department Access:</strong> <%= adminScopeDepartmentLabel %></p>
        <% } %>

        <div class="stats compact">
          <div>
            <strong><%= stats.total %></strong>
            <span>Total</span>
          </div>
          <div>
            <strong><%= stats.pending %></strong>
            <span>Pending</span>
          </div>
          <div>
            <strong><%= stats.needsCorrection %></strong>
            <span>Needs Correction</span>
          </div>
          <div>
            <strong><%= stats.verified %></strong>
            <span>Verified</span>
          </div>
          <div>
            <strong><%= stats.approved %></strong>
            <span>Approved</span>
          </div>
          <div>
            <strong><%= stats.rejected %></strong>
            <span>Rejected</span>
          </div>
        </div>

        <form method="get" action="/admin/applications" class="filter-row">
          <label>
            Filter by status
            <select name="status">
              <option value="All" <%= statusFilter === 'All' ? 'selected' : '' %>>All</option>
              <option value="Pending" <%= statusFilter === 'Pending' ? 'selected' : '' %>>Pending</option>
              <option value="Needs Correction" <%= statusFilter === 'Needs Correction' ? 'selected' : '' %>>Needs Correction</option>
              <option value="Verified" <%= statusFilter === 'Verified' ? 'selected' : '' %>>Verified</option>
              <option value="Approved" <%= statusFilter === 'Approved' ? 'selected' : '' %>>Approved</option>
              <option value="Rejected" <%= statusFilter === 'Rejected' ? 'selected' : '' %>>Rejected</option>
            </select>
          </label>
          <% if (isSuperAdmin && !adminScopeDepartment) { %>
            <label>
              Filter by applied department
              <select name="department">
                <option value="All" <%= departmentFilter === 'All' ? 'selected' : '' %>>All departments</option>
                <% departmentOptions.forEach((department) => { %>
                  <option value="<%= department.key %>" <%= departmentFilter === department.key ? 'selected' : '' %>>
                    <%= department.label %>
                  </option>
                <% }) %>
              </select>
            </label>
          <% } else { %>
            <input type="hidden" name="department" value="<%= departmentFilter %>" />
          <% } %>
          <button class="btn" type="submit">Apply Filter</button>
        </form>

        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>ID</th>
                <th>Tracking Number</th>
                <th>Name</th>
                <th>Email</th>
                <th>Institution</th>
                <th>Applied Department</th>
                <th>Assigned Department</th>
                <th>Period</th>
                <th>Status</th>
                <th>Submitted</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% if (!applications.length) { %>
                <tr>
                  <td colspan="11">No applications found for this filter.</td>
                </tr>
              <% } %>

              <% applications.forEach((application) => { %>
                <tr>
                  <td><%= application.id %></td>
                  <td><%= application.placementNumber || application.id %></td>
                  <td><%= application.fullName %></td>
                  <td><%= application.email %></td>
                  <td><%= application.institution %></td>
                  <td><%= application.appliedDepartment ? getDepartmentLabel(application.appliedDepartment) : 'Not set' %></td>
                  <td><%= application.assignedDepartment ? getDepartmentLabel(application.assignedDepartment) : 'Not assigned' %></td>
                  <td><%= application.period ? getPeriodLabel(application.period) : 'Not set' %></td>
                  <td><span class="badge <%= getStatusClass(application.status) %>"><%= application.status %></span></td>
                  <td><%= formatDate(application.submittedAt) %></td>
                  <td>
                    <div class="table-actions">
                      <a href="/admin/applications/<%= application.id %>">Review</a>
                      <form action="/admin/applications/<%= application.id %>/delete" method="post" onsubmit="return confirm('Delete this applicant and all uploaded documents? This cannot be undone.');">
                        <button type="submit" class="link-btn danger-text">Delete</button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>
    </main>
<%- include("partials/layout-close") %>


<%- include("partials/layout-open", { pageTitle: "Apply - County Attachment Portal", activePortal: "student" }) %>
<main class="container">
  <section class="card">
    <h1>Attachment Application Form</h1>
    <p>
      Start with the department and institution selection first. If the student is applying as a PWD or special applicant, choose that category and provide the reason so the system can handle the special path correctly.
    </p>

    <% if (error) { %>
      <div class="alert"><%= error %></div>
    <% } %>

    <% if (!hasOpenPeriods) { %>
      <div class="alert">
        Applications are currently closed for all periods. Check the landing page runner for the next county opening.
      </div>
    <% } %>

    <% if (slotsFull) { %>
      <div class="alert">
        Ordinary application slots are currently full for this intake. Declared PWD or special applicants can still continue after explaining their condition for county review.
      </div>
    <% } %>

    <% if (remainingApplicants !== null) { %>
      <div class="summary">
        <p><strong>Application Capacity:</strong> <%= maxApplicants %></p>
        <p><strong>Remaining Slots:</strong> <%= remainingApplicants %></p>
        <p>
          <strong>Institution Fairness Rule:</strong>
          A single institution can use up to <%= institutionMaxSharePercent %>% of each department's slots.
        </p>
      </div>
    <% } %>

    <div class="summary">
      <h3>Requirements Before You Apply</h3>
      <ul class="requirements-list">
        <% applicationRequirements.forEach((requirement) => { %>
          <li><%= requirement %></li>
        <% }) %>
      </ul>
    </div>

    <div class="summary">
      <h3>County Terms And Conditions</h3>
      <ul class="requirements-list">
        <% applicationTerms.forEach((term) => { %>
          <li><%= term %></li>
        <% }) %>
      </ul>
      <p class="field-hint">
        These terms are aligned with the County Government of Uasin Gishu online application and induction requirements.
      </p>
    </div>

    <% if (canStartApplication) { %>
      <form action="/apply" method="post" enctype="multipart/form-data" class="form-grid" id="applyForm">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <section class="selection-panel full-width terms-checkpoint">
          <div class="selection-panel-header">
            <div>
              <p class="eyebrow">Step 1</p>
              <h2>Accept county terms before you continue</h2>
            </div>
            <div class="selection-panel-note">
              The agreement is recorded with the application for county review.
            </div>
          </div>

          <label class="full-width terms-consent">
            <span class="terms-consent-row">
              <input
                id="acceptedTermsGate"
                type="checkbox"
                name="acceptedTerms"
                value="yes"
                <%= formData.acceptedTerms === 'yes' ? 'checked' : '' %>
                required
              />
              <span>
                I agree to the County Government of Uasin Gishu attachment application terms and conditions, and I understand this acceptance is recorded with my application.
              </span>
            </span>
          </label>
        </section>

        <section class="selection-panel full-width">
          <div class="selection-panel-header">
            <div>
              <p class="eyebrow">Step 2</p>
              <h2>Choose department and institution first</h2>
            </div>
          </div>

          <div class="selection-grid">
            <label>
              Department Applied For *
              <select id="appliedDepartmentSelect" name="appliedDepartment" required <%= formData.acceptedTerms === 'yes' ? '' : 'disabled' %>>
                <option value="">Select department</option>
                <% departmentOptions.forEach((department) => { %>
                  <option value="<%= department.key %>" <%= formData.appliedDepartment === department.key ? 'selected' : '' %>>
                    <%= department.label %>
                  </option>
                <% }) %>
              </select>
            </label>

            <label>
              PWD / Special Applicant
              <select id="disabilityStatusSelect" name="disabilityStatus" <%= formData.acceptedTerms === 'yes' ? '' : 'disabled' %>>
                <option value="" <%= !formData.disabilityStatus ? 'selected' : '' %>>Normal applicant</option>
                <option value="pwd" <%= formData.disabilityStatus === 'pwd' || formData.disabilityStatus === 'yes' ? 'selected' : '' %>>PWD applicant</option>
                <option value="special" <%= formData.disabilityStatus === 'special' ? 'selected' : '' %>>Special applicant</option>
              </select>
              <span class="field-hint">
                Leave this as normal applicant unless the student is applying under the PWD or special-applicant path.
              </span>
            </label>

            <label>
              Institution *
              <select
                id="institutionSelect"
                name="institution"
                required
                <%= formData.acceptedTerms === 'yes' && formData.appliedDepartment ? '' : 'disabled' %>
              >
                <option value="">Select institution</option>
                <% institutionGroups.forEach((group) => { %>
                  <optgroup label="<%= group.category %>">
                    <% group.institutions.forEach((institution) => { %>
                      <option value="<%= institution %>" <%= formData.institution === institution ? 'selected' : '' %>><%= institution %></option>
                    <% }) %>
                  </optgroup>
                <% }) %>
                <option value="<%= otherInstitutionValue %>" <%= formData.institution === otherInstitutionValue ? 'selected' : '' %>>Other - type institution in full</option>
              </select>
              <span class="field-hint">
                Choose from the ranked institution list. If your institution is missing, select <strong>Other</strong> and type the full institution name without abbreviations.
              </span>
            </label>

            <label
              id="otherInstitutionLabel"
              class="full-width <%= formData.institution === otherInstitutionValue ? '' : 'is-hidden' %>"
            >
              Other Institution Name *
              <span class="field-hint">
                Enter the institution name in full so it can be recorded properly. Do not use abbreviations.
              </span>
              <input
                id="otherInstitutionInput"
                type="text"
                name="otherInstitution"
                value="<%= formData.otherInstitution || '' %>"
                placeholder="Example: Kenya School of Government"
                <%= formData.institution === otherInstitutionValue ? 'required' : '' %>
              />
            </label>
          </div>

          <label
            id="pwdReasonLabel"
            class="full-width <%= formData.disabilityStatus === 'pwd' || formData.disabilityStatus === 'yes' ? '' : 'is-hidden' %>"
          >
            PWD Explanation *
            <span class="field-hint">
              If PWD applicant is selected, explain the disability or accommodation reason clearly.
            </span>
            <textarea
              id="pwdReasonInput"
              name="pwdReason"
              rows="4"
              placeholder="State the disability and any accommodation or consideration needed."
              <%= formData.disabilityStatus === 'pwd' || formData.disabilityStatus === 'yes' ? 'required' : '' %>
            ><%= formData.disabilityStatus === 'pwd' || formData.disabilityStatus === 'yes' ? (formData.pwdReason || formData.disabilityReason || '') : (formData.pwdReason || '') %></textarea>
          </label>

          <label
            id="specialApplicantReasonLabel"
            class="full-width <%= formData.disabilityStatus === 'special' ? '' : 'is-hidden' %>"
          >
            Special Applicant Explanation *
            <span class="field-hint">
              If special applicant is selected, explain the reason for the special consideration clearly.
            </span>
            <textarea
              id="specialApplicantReasonInput"
              name="specialApplicantReason"
              rows="4"
              placeholder="State the reason for special-applicant consideration."
              <%= formData.disabilityStatus === 'special' ? 'required' : '' %>
            ><%= formData.disabilityStatus === 'special' ? (formData.specialApplicantReason || formData.disabilityReason || '') : (formData.specialApplicantReason || '') %></textarea>
          </label>

          <div
            id="institutionSlotBox"
            class="selection-status-card tone-<%= formData.acceptedTerms !== 'yes' ? 'muted' : (selectedInstitutionAvailability.specialApplicantReasonRequired ? 'warning' : (showApplicationFields ? 'success' : (selectedInstitutionAvailability.institutionResolutionError || selectedInstitutionAvailability.isDepartmentFull || selectedInstitutionAvailability.isInstitutionFull ? 'danger' : 'muted'))) %>"
          >
            <strong id="institutionStatusHeading">
              <%= formData.acceptedTerms !== 'yes' ? 'Accept the county terms first.' : (selectedInstitutionAvailability.specialApplicantReasonRequired ? 'PWD or special applicant explanation required.' : (showApplicationFields ? 'You can continue with the application.' : 'Department and institution required.')) %>
            </strong>
            <p id="institutionStatusMessage" class="selection-status-message">
              <% if (formData.acceptedTerms !== 'yes') { %>
                Accept the county terms and conditions first. The department and institution fields will unlock immediately after you agree.
              <% } else if (!formData.appliedDepartment) { %>
                Select the department first, then choose the institution to confirm whether that institution still has room in the department.
              <% } else if (selectedInstitutionAvailability.specialApplicantReasonRequired) { %>
                Because you selected the PWD or special-applicant path, you must explain the reason before continuing.
              <% } else if (!formData.institution) { %>
                Department selected. Choose the institution next so the system can confirm the remaining institution slots.
              <% } else if (selectedInstitutionAvailability.institutionResolutionError) { %>
                <%= selectedInstitutionAvailability.institutionResolutionError %>
              <% } else if (showApplicationFields && selectedInstitutionAvailability.specialApplicant && selectedInstitutionAvailability.canBypassLimits) { %>
                Special-applicant path active. You can continue with the application even if ordinary department or institution slot limits are full. HR will review the explanation you provided.
              <% } else if (showApplicationFields) { %>
                <%= selectedInstitutionAvailability.institutionLabel %> can still use <%= selectedInstitutionAvailability.institutionRemaining %> of <%= selectedInstitutionAvailability.institutionLimit %> institution slot(s) in <%= selectedInstitutionAvailability.departmentLabel %>.
              <% } else if (selectedInstitutionAvailability.isDepartmentFull) { %>
                <%= selectedInstitutionAvailability.departmentLabel %> has no remaining department slots.
              <% } else if (selectedInstitutionAvailability.isInstitutionFull) { %>
                <%= selectedInstitutionAvailability.institutionLabel %> has no institution slots remaining in <%= selectedInstitutionAvailability.departmentLabel %>. Choose another institution or department.
              <% } else { %>
                Choose the department and institution to confirm whether you can continue.
              <% } %>
            </p>
            <div class="selection-status-metrics" id="institutionStatusMetrics">
              <% if (formData.acceptedTerms === 'yes' && formData.appliedDepartment) { %>
                <span>
                  Department remaining:
                  <strong><%= selectedInstitutionAvailability.departmentRemaining %></strong>
                </span>
                <span>
                  Institution limit:
                  <strong><%= selectedInstitutionAvailability.institutionLimit %></strong>
                </span>
                <% if (formData.institution && selectedInstitutionAvailability.institutionSelected) { %>
                  <span>
                    Institution remaining:
                    <strong><%= selectedInstitutionAvailability.institutionRemaining %></strong>
                  </span>
                <% } %>
                <% if (selectedInstitutionAvailability.specialApplicant && selectedInstitutionAvailability.canBypassLimits) { %>
                  <span>
                    Special applicant override:
                    <strong>Active</strong>
                  </span>
                <% } %>
              <% } %>
            </div>
          </div>
        </section>

        <section
          id="applicationFields"
          class="application-fields full-width <%= showApplicationFields && formData.acceptedTerms === 'yes' ? '' : 'is-hidden' %>"
          aria-hidden="<%= showApplicationFields && formData.acceptedTerms === 'yes' ? 'false' : 'true' %>"
        >
          <div class="application-fields-header">
            <p class="eyebrow">Step 3</p>
            <h2>Complete the application details</h2>
          </div>

          <div class="form-grid nested-form-grid">
            <label>
              Full Name *
              <input type="text" name="fullName" value="<%= formData.fullName || '' %>" required />
            </label>

            <label>
              Email Address *
              <input type="email" name="email" value="<%= formData.email || '' %>" required />
            </label>

            <label>
              Phone Number *
              <input type="text" name="phone" value="<%= formData.phone || '' %>" required />
            </label>

            <label>
              ID Number *
              <input
                type="text"
                name="idNumber"
                value="<%= formData.idNumber || '' %>"
                placeholder="Example: 12345678"
                required
              />
            </label>

            <label>
              Disability / Special Applicant
              <input
                type="text"
                value="<%= getDisabilityStatusLabel(formData.disabilityStatus) %>"
                readonly
              />
            </label>

            <label>
              Course/Program *
              <input type="text" name="course" value="<%= formData.course || '' %>" required />
            </label>

            <label>
              Course Level *
              <select name="courseLevel" required>
                <option value="">Select course level</option>
                <% courseLevelOptions.forEach((option) => { %>
                  <option
                    value="<%= option.key %>"
                    <%= formData.courseLevel === option.key ? 'selected' : '' %>
                  >
                    <%= option.label %>
                  </option>
                <% }) %>
              </select>
            </label>

            <label>
              Attachment Period *
              <select name="period" required>
                <option value="">Select period</option>
                <% periodOptions.forEach((period) => { %>
                  <option
                    value="<%= period.key %>"
                    <%= formData.period === period.key ? 'selected' : '' %>
                    <%= !period.isOpen ? 'disabled' : '' %>
                  >
                    <%= period.label %> <%= period.quarterLabel ? `(${period.quarterLabel})` : '' %> - <%= period.statusLabel %>
                  </option>
                <% }) %>
              </select>
            </label>

            <label>
              Attachment Start Date *
              <input type="date" name="startDate" value="<%= formData.startDate || '' %>" required />
            </label>

            <label>
              Attachment End Date *
              <input type="date" name="endDate" value="<%= formData.endDate || '' %>" required />
            </label>

            <label class="full-width">
              Cover Note / Self Introduction *
              <span class="field-hint">
                Briefly write an application explaination of who you are, your institution, course/program, level of the program, attachment goals, and why you are applying.
              </span>
              <textarea
                name="coverNote"
                rows="5"
                placeholder="Example: I am a third-year Information Technology student at University of Eldoret seeking attachment to build practical skills in county systems and public service delivery."
                required
              ><%= formData.coverNote || '' %></textarea>
            </label>

            <label class="full-width">
              <%= combinedDocumentDefinition.label %> *
              <span class="field-hint">
                Upload one scanned file in PDF or DOCX format that includes passport photo, school cover letter, insurance copy, and both sides of your national ID or school ID.
                A separate application letter is not required because you have already written the cover note above.
              </span>
              <input
                type="file"
                name="<%= combinedDocumentDefinition.key %>"
                accept="<%= combinedDocumentDefinition.accept %>"
                required
              />
            </label>

            <label class="full-width">
              <%= nitaDocumentDefinition.label %> *
              <span class="field-hint">
                Upload the NITA document separately as a PDF with your school stamp. The system will automatically generate a county-endorsed copy for you to download, take to the NITA office for stamping, and re-submit from the student dashboard.
              </span>
              <input
                type="file"
                name="<%= nitaDocumentDefinition.key %>"
                accept="<%= nitaDocumentDefinition.accept %>"
                required
              />
              <button type="button" class="btn secondary use-test-nita-btn" data-target-name="<%= nitaDocumentDefinition.key %>" style="margin-top: 0.5rem; padding: 0.35rem 0.7rem; font-size: 0.78rem; display: inline-flex; align-items: center; gap: 0.3rem; border-radius: 8px; font-weight: 600; width: fit-content; cursor: pointer;">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="vertical-align: middle;">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                  <polyline points="7 10 12 15 17 10"></polyline>
                  <line x1="12" y1="15" x2="12" y2="3"></line>
                </svg>
                <span>Use Default Test NITA Form</span>
              </button>
            </label>

            <div class="full-width actions">
              <button id="applySubmitButton" class="btn" type="submit" <%= showApplicationFields && formData.acceptedTerms === 'yes' ? '' : 'disabled' %>>
                Submit Application
              </button>
              <a class="btn secondary" href="/">Cancel</a>
            </div>
          </div>
        </section>
      </form>
    <% } %>
  </section>
</main>

<% if (canStartApplication) { %>
  <script>
    (() => {
      const termsCheckbox = document.getElementById("acceptedTermsGate");
      const departmentSelect = document.getElementById("appliedDepartmentSelect");
      const disabilityStatusSelect = document.getElementById("disabilityStatusSelect");
      const pwdReasonLabel = document.getElementById("pwdReasonLabel");
      const pwdReasonInput = document.getElementById("pwdReasonInput");
      const specialApplicantReasonLabel = document.getElementById("specialApplicantReasonLabel");
      const specialApplicantReasonInput = document.getElementById("specialApplicantReasonInput");
      const institutionSelect = document.getElementById("institutionSelect");
      const otherInstitutionLabel = document.getElementById("otherInstitutionLabel");
      const otherInstitutionInput = document.getElementById("otherInstitutionInput");
      const applicationFields = document.getElementById("applicationFields");
      const statusBox = document.getElementById("institutionSlotBox");
      const statusHeading = document.getElementById("institutionStatusHeading");
      const statusMessage = document.getElementById("institutionStatusMessage");
      const statusMetrics = document.getElementById("institutionStatusMetrics");
      const submitButton = document.getElementById("applySubmitButton");

      if (!termsCheckbox || !departmentSelect || !disabilityStatusSelect || !pwdReasonLabel || !pwdReasonInput || !specialApplicantReasonLabel || !specialApplicantReasonInput || !institutionSelect || !otherInstitutionLabel || !otherInstitutionInput || !applicationFields || !statusBox || !statusHeading || !statusMessage || !statusMetrics || !submitButton) {
        return;
      }

      let controller = null;

      function setTone(tone) {
        statusBox.classList.remove("tone-muted", "tone-success", "tone-warning", "tone-danger");
        statusBox.classList.add(`tone-${tone}`);
      }

      function setFieldsVisible(visible) {
        applicationFields.classList.toggle("is-hidden", !visible);
        applicationFields.setAttribute("aria-hidden", visible ? "false" : "true");
        submitButton.disabled = !visible;
      }

      function renderMetrics(data) {
        const metrics = [];

        if (data.departmentSelected) {
          metrics.push(
            `<span>Department remaining: <strong>${Number(data.departmentRemaining || 0)}</strong></span>`
          );
          metrics.push(
            `<span>Institution limit: <strong>${Number(data.institutionLimit || 0)}</strong></span>`
          );
        }

        if (data.institutionSelected) {
          metrics.push(
            `<span>Institution remaining: <strong>${Number(data.institutionRemaining || 0)}</strong></span>`
          );
        }

        if (data.specialApplicant && data.canBypassLimits) {
          metrics.push("<span>Special applicant override: <strong>Active</strong></span>");
        }

        statusMetrics.innerHTML = metrics.join("");
      }

      function syncDisabilityUi() {
        const isPwdApplicant = ["pwd", "yes"].includes(disabilityStatusSelect.value);
        const isSpecialApplicant = disabilityStatusSelect.value === "special";
        pwdReasonLabel.classList.toggle("is-hidden", !isPwdApplicant);
        specialApplicantReasonLabel.classList.toggle("is-hidden", !isSpecialApplicant);
        pwdReasonInput.required = isPwdApplicant;
        specialApplicantReasonInput.required = isSpecialApplicant;
      }

      function syncInstitutionUi() {
        const usingOtherInstitution = institutionSelect.value === "<%= otherInstitutionValue %>";
        otherInstitutionLabel.classList.toggle("is-hidden", !usingOtherInstitution);
        otherInstitutionInput.required = usingOtherInstitution;
        otherInstitutionInput.disabled =
          !termsCheckbox.checked ||
          !departmentSelect.value.trim() ||
          !usingOtherInstitution;
      }

      function renderDefaultState() {
        setTone("muted");
        statusHeading.textContent = "Accept the county terms first.";
        statusMessage.textContent =
          "Accept the county terms and conditions first. The department and institution fields will unlock immediately after you agree.";
        statusMetrics.innerHTML = "";
        departmentSelect.disabled = !termsCheckbox.checked;
        disabilityStatusSelect.disabled = !termsCheckbox.checked;
        pwdReasonInput.disabled = !termsCheckbox.checked || !["pwd", "yes"].includes(disabilityStatusSelect.value);
        specialApplicantReasonInput.disabled = !termsCheckbox.checked || disabilityStatusSelect.value !== "special";
        institutionSelect.disabled = true;
        otherInstitutionInput.disabled = true;
        syncDisabilityUi();
        syncInstitutionUi();
        setFieldsVisible(false);
      }

      async function refreshAvailability() {
        if (!termsCheckbox.checked) {
          renderDefaultState();
          return;
        }

        const department = departmentSelect.value.trim();
        const disabilityStatus = disabilityStatusSelect.value.trim();
        const pwdReason = pwdReasonInput.value.trim();
        const specialApplicantReason = specialApplicantReasonInput.value.trim();
        const disabilityReason = disabilityStatus === "special" ? specialApplicantReason : pwdReason;
        const institution = institutionSelect.value.trim();
        const otherInstitution = otherInstitutionInput.value.trim();

        departmentSelect.disabled = false;
        disabilityStatusSelect.disabled = false;
        pwdReasonInput.disabled = !["pwd", "yes"].includes(disabilityStatus);
        specialApplicantReasonInput.disabled = disabilityStatus !== "special";
        syncDisabilityUi();
        institutionSelect.disabled = !department;
        syncInstitutionUi();

        if (!department) {
          setTone("muted");
          statusHeading.textContent = "Department and institution selection required.";
          statusMessage.textContent =
            "Select the department first, then choose the institution to confirm whether that institution still has room in the department.";
          statusMetrics.innerHTML = "";
          setFieldsVisible(false);
          return;
        }

        if (controller) {
          controller.abort();
        }

        controller = new AbortController();

        try {
          const response = await fetch(
            `/api/institution-availability?department=${encodeURIComponent(department)}&institution=${encodeURIComponent(institution)}&otherInstitution=${encodeURIComponent(otherInstitution)}&disabilityStatus=${encodeURIComponent(disabilityStatus)}&disabilityReason=${encodeURIComponent(disabilityReason)}`,
            { signal: controller.signal }
          );

          if (!response.ok) {
            throw new Error("Failed to check institution availability.");
          }

          const data = await response.json();
          renderMetrics(data);

          if (data.specialApplicantReasonRequired) {
            setTone("warning");
            statusHeading.textContent = "PWD or special applicant explanation required.";
            statusMessage.textContent =
              "Because you selected the PWD or special-applicant path, you must explain the reason before continuing.";
            setFieldsVisible(false);
            return;
          }

          if (!institution) {
            setTone("muted");
            statusHeading.textContent = "Institution selection required.";
            statusMessage.textContent =
              `${data.departmentLabel} selected. Choose the institution next so the system can confirm the remaining institution slots.`;
            setFieldsVisible(false);
            return;
          }

          if (!data.institutionSelected) {
            setTone("danger");
            statusHeading.textContent = "Institution not recognised.";
            statusMessage.textContent =
              data.institutionResolutionError ||
              "Please choose a recognised institution from the dropdown or use Other and type the institution name in full.";
            setFieldsVisible(false);
            return;
          }

          if (data.specialApplicant && data.canBypassLimits) {
            setTone("success");
            statusHeading.textContent = "PWD / special-applicant path confirmed.";
            statusMessage.textContent =
              "PWD / special-applicant override is active. You can continue with the application and HR will review the explanation you provided.";
            setFieldsVisible(true);
            return;
          }

          if (data.isDepartmentFull) {
            setTone("danger");
            statusHeading.textContent = "Department slots are full.";
            statusMessage.textContent =
              `${data.departmentLabel} has no remaining department slots. Choose another department.`;
            setFieldsVisible(false);
            return;
          }

          if (data.isInstitutionFull) {
            setTone("danger");
            statusHeading.textContent = "Institution limit reached.";
            statusMessage.textContent =
              `${data.institutionLabel} has no institution slots remaining in ${data.departmentLabel}. Choose another institution or department.`;
            setFieldsVisible(false);
            return;
          }

          setTone(data.institutionRemaining <= 1 ? "warning" : "success");
          statusHeading.textContent = "You can continue with the application.";
          statusMessage.textContent =
            `${data.institutionLabel} can still use ${data.institutionRemaining} of ${data.institutionLimit} institution slot(s) in ${data.departmentLabel}.`;
          setFieldsVisible(true);
        } catch (error) {
          if (error.name === "AbortError") {
            return;
          }

          setTone("warning");
          statusHeading.textContent = "Availability check unavailable.";
          statusMessage.textContent =
            "The institution slot check is temporarily unavailable. Reload the page and try again.";
          setFieldsVisible(false);
          statusMetrics.innerHTML = "";
        }
      }

      termsCheckbox.addEventListener("change", refreshAvailability);
      departmentSelect.addEventListener("change", refreshAvailability);
      disabilityStatusSelect.addEventListener("change", refreshAvailability);
      pwdReasonInput.addEventListener("input", refreshAvailability);
      pwdReasonInput.addEventListener("change", refreshAvailability);
      specialApplicantReasonInput.addEventListener("input", refreshAvailability);
      specialApplicantReasonInput.addEventListener("change", refreshAvailability);
      institutionSelect.addEventListener("change", refreshAvailability);
      otherInstitutionInput.addEventListener("input", refreshAvailability);
      otherInstitutionInput.addEventListener("change", refreshAvailability);
      // Test NITA Pre-population Logic
      document.addEventListener("click", async (e) => {
        const btn = e.target.closest(".use-test-nita-btn");
        if (!btn) return;
        
        const targetName = btn.dataset.targetName;
        const fileInput = document.querySelector(`input[type="file"][name="${targetName}"]`);
        if (!fileInput) return;

        const originalText = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = `
          <span class="loading-spinner" style="margin-right: 0.2rem; vertical-align: middle;"></span>
          <span>Loading template...</span>
        `;

        try {
          const response = await fetch("/testing-nita-template.pdf");
          if (!response.ok) throw new Error("Failed to fetch template");
          const blob = await response.blob();
          const file = new File([blob], "testing-nita-template.pdf", { type: "application/pdf" });
          
          const dataTransfer = new DataTransfer();
          dataTransfer.items.add(file);
          fileInput.files = dataTransfer.files;

          fileInput.dispatchEvent(new Event("change", { bubbles: true }));

          btn.style.background = "var(--success)";
          btn.style.color = "#ffffff";
          btn.innerHTML = `
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 0.2rem; vertical-align: middle;">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span>Test NITA Loaded!</span>
          `;
        } catch (err) {
          console.error(err);
          btn.style.background = "var(--danger)";
          btn.style.color = "#ffffff";
          btn.innerHTML = `<span>Error loading template</span>`;
          setTimeout(() => {
            btn.disabled = false;
            btn.style.background = "";
            btn.style.color = "";
            btn.innerHTML = originalText;
          }, 2000);
        }
      });

      refreshAvailability();
    })();
  </script>
<% } %>

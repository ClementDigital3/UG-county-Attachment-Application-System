<%- include("partials/layout-open", { pageTitle: "Manage Period Windows", activePortal: "hr" }) %>
<main class="container">
      <section class="card">
        <div class="row-between">
          <h1><%= isHrAdmin ? 'HR Period and Slot Control' : 'Department Slot Control' %></h1>
          <div class="actions tight">
            <% if (isHrAdmin) { %>
              <a class="btn secondary" href="/hr/departments">Department Review</a>
              <a class="btn secondary" href="/hr/communications">Communications</a>
              <a class="btn secondary" href="/hr/audit">Audit Trail</a>
              <a class="btn secondary" href="/hr/reports">Reports</a>
              <a class="btn secondary" href="/hr/admin-accounts">Admin Accounts</a>
              <a class="btn secondary" href="/hr/account">HR Account</a>
              <a class="btn secondary" href="/hr/applications">HR Queue</a>
            <% } else { %>
              <a class="btn secondary" href="/admin/reports">Reports</a>
              <a class="btn secondary" href="/admin/departments">Departments</a>
              <a class="btn secondary" href="/admin/applications">Applications</a>
            <% } %>
            <form action="<%= isHrAdmin ? '/hr/logout' : '/admin/logout' %>" method="post">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <button class="btn secondary" type="submit">Logout</button>
            </form>
          </div>
        </div>

        <% if (canManageOpenPeriods) { %>
          <p>
            Open the quarterly attachment windows, set the homepage runner message, and define the application deadline.
          </p>
        <% } else { %>
          <p>
            You can set the attachment slots for your department.
            Period windows are controlled by the system administrator.
          </p>
        <% } %>

        <% if (adminScopeDepartmentLabel) { %>
          <p><strong>Department Access:</strong> <%= adminScopeDepartmentLabel %></p>
        <% } %>

        <div class="summary">
          <p><strong>Current document storage:</strong> <%= fileStorageProvider === 'mongodb' ? 'MongoDB GridFS document storage' : 'Legacy compatibility mode' %></p>
          <% if (fileStorageWarning) { %>
            <p><strong>Storage warning:</strong> <%= fileStorageWarning %></p>
          <% } %>
        </div>

        <% if (saved) { %>
          <div class="notice">Period settings updated successfully.</div>
        <% } %>

        <% if (error) { %>
          <div class="alert"><%= error %></div>
        <% } %>

        <form action="<%= isHrAdmin ? '/hr/periods' : '/admin/periods' %>" method="post" class="form-grid">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <% if (canManageOpenPeriods) { %>
            <label class="full-width">
              Landing Page Runner Message
              <input
                type="text"
                name="landingTickerText"
                maxlength="180"
                value="<%= landingTickerText || '' %>"
                placeholder="Attachment applications are ongoing. Submit before the county deadline."
              />
              <span class="field-hint">Short message shown in the moving announcement strip on the landing page.</span>
            </label>

            <label>
              Application Deadline
              <input type="date" name="applicationDeadline" value="<%= applicationDeadline || '' %>" />
            </label>

            <div class="full-width period-admin-grid">
              <% periodOptions.forEach((period) => { %>
                <label class="checkbox-card">
                  <input type="checkbox" name="openPeriods" value="<%= period.key %>" <%= period.isConfiguredOpen ? 'checked' : '' %> />
                  <span><%= period.shortLabel || period.label %> <%= period.quarterLabel ? `(${period.quarterLabel})` : '' %></span>
                </label>
              <% }) %>
            </div>
          <% } %>

          <label class="full-width">
            Institution Fairness Ratio (%)
            <% if (canManageOpenPeriods) { %>
              <input
                type="number"
                name="institutionMaxSharePercent"
                min="1"
                max="100"
                step="1"
                value="<%= Number(institutionMaxSharePercent || 40) %>"
                required
              />
            <% } else { %>
              <input type="number" value="<%= Number(institutionMaxSharePercent || 40) %>" readonly />
            <% } %>
            <span class="field-hint">
              Maximum share of each department's slots that one institution can use.
            </span>
          </label>

          <div class="full-width">
            <h2>Department Slot Capacity</h2>
            <div class="form-grid">
              <% editableDepartments.forEach((department) => { %>
                <label>
                  <%= department.label %>
                  <input
                    type="number"
                    name="capacity_<%= department.key %>"
                    min="0"
                    step="1"
                    value="<%= Number(departmentCapacities[department.key] || 0) %>"
                    required
                  />
                </label>
              <% }) %>
            </div>
          </div>

          <label class="full-width">
            Total Capacity (All Departments)
            <input type="number" value="<%= maxApplicants %>" readonly />
            <span class="field-hint">Landing page remaining slots are calculated from total department capacities.</span>
          </label>

          <div class="actions full-width">
            <button class="btn" type="submit"><%= canManageOpenPeriods ? 'Save Period Windows And Slot Capacity' : 'Save Department Slot Capacity' %></button>
          </div>
        </form>

        <% if (isHrAdmin) { %>
          <hr class="section-divider" style="margin: 2.5rem 0; border: 0; border-top: 1px dashed #ccc;" />
          <section class="backup-restore-section" style="margin-top: 1.5rem;">
            <h2 style="margin-bottom: 0.5rem;">System Database Backup & Restore</h2>
            <p class="field-hint" style="margin-bottom: 1.5rem; line-height: 1.4;">
              Export a compressed backup containing all application records, settings, and logs. In case of server migration or database failure, upload this backup file to restore the entire portal state.
            </p>
            
            <div style="display: flex; gap: 1.5rem; flex-wrap: wrap;">
              <!-- Export Box -->
              <div style="flex: 1; min-width: 280px; border: 1px solid #ddd; padding: 1.5rem; border-radius: 6px; background-color: #fafafa;">
                <h3 style="margin-top: 0; margin-bottom: 0.5rem; font-size: 1.1rem; color: #1b5e20;">Export Database</h3>
                <p class="field-hint" style="margin-bottom: 1.5rem;">Download a gzip-compressed backup file containing all portal data.</p>
                <a href="/hr/backup/export" class="btn" style="display: inline-block; text-align: center; text-decoration: none; font-size: 0.9rem; padding: 0.6rem 1.2rem;">Download Backup (.json.gz)</a>
              </div>
              
              <!-- Restore Box -->
              <div style="flex: 1; min-width: 280px; border: 1px solid #ddd; padding: 1.5rem; border-radius: 6px; background-color: #fafafa;">
                <h3 style="margin-top: 0; margin-bottom: 0.5rem; font-size: 1.1rem; color: #b71c1c;">Restore Database</h3>
                <p class="field-hint" style="margin-bottom: 1rem; color: #b71c1c;">⚠️ Warning: Restoring a backup completely overwrites all current database collections.</p>
                <form action="/hr/backup/restore" method="post" enctype="multipart/form-data" onsubmit="return confirm('Are you sure you want to restore? This will overwrite the entire database.');">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <div style="margin-bottom: 1rem;">
                    <input type="file" name="backupFile" accept=".json.gz" required style="display: block; width: 100%; border: 1px solid #ccc; padding: 0.4rem; border-radius: 4px; font-size: 0.85rem;" />
                  </div>
                  <button type="submit" class="btn" style="background-color: #b71c1c; border-color: #b71c1c; color: white; font-size: 0.9rem; padding: 0.6rem 1.2rem;">Restore Database Backup</button>
                </form>
              </div>
            </div>
          </section>
        <% } %>

        <p class="muted-note">Last updated: <%= formatDate(updatedAt) %></p>
      </section>
    </main>
<%- include("partials/layout-close") %>


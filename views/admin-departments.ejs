<%- include("partials/layout-open", { pageTitle: "Department Review Access", activePortal: "hr" }) %>
<main class="container wide">
      <section class="card">
        <div class="row-between">
          <h1>Department Review Access</h1>
          <div class="actions tight">
            <a class="btn secondary" href="/hr/applications">HR Queue</a>
            <a class="btn secondary" href="/hr/reports">Reports</a>
            <a class="btn secondary" href="/hr/periods">Period and Slot Settings</a>
            <form action="/hr/logout" method="post">
              <button class="btn secondary" type="submit">Logout</button>
            </form>
          </div>
        </div>

        <p>
          HR authorizes department review. Open any department below to review applications, request
          corrections, verify records, or export that department's records.
        </p>

        <section class="portal-grid">
          <% departmentSummaries.forEach((department) => { %>
            <article class="card portal-card">
              <h2><%= department.label %></h2>
              <div class="summary">
                <p><strong>Applied:</strong> <%= department.appliedCount %></p>
                <p><strong>Assigned:</strong> <%= department.assignedCount %></p>
                <p><strong>Pending:</strong> <%= department.pendingCount %></p>
              </div>
              <div class="actions">
                <a class="btn" href="/hr/departments/<%= department.key %>/open">Open Department Review</a>
                <a class="btn secondary" href="/hr/reports/export.csv?status=All&period=All&department=<%= department.key %>">Export Department Records</a>
              </div>
            </article>
          <% }) %>
        </section>
      </section>
    </main>
<%- include("partials/layout-close") %>

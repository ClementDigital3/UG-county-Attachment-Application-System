<%- include("partials/layout-open", { pageTitle: "HR Supervisors", activePortal: "hr" }) %>
<main class="container wide">
      <section class="card">
        <div class="row-between">
          <h1>HR Supervisors</h1>
          <div class="actions tight">
            <a class="btn secondary" href="/hr/departments">Department Review</a>
            <a class="btn secondary" href="/hr/communications">Communications</a>
            <a class="btn secondary" href="/hr/audit">Audit Trail</a>
            <a class="btn secondary" href="/hr/reports">Reports</a>
            <a class="btn secondary" href="/hr/admin-accounts">Admin Accounts</a>
            <a class="btn secondary" href="/hr/account">HR Account</a>
            <a class="btn secondary" href="/hr/periods">Period and Slot Settings</a>
            <a class="btn secondary" href="/hr/applications">Back to HR Queue</a>
            <form action="/hr/logout" method="post">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <button class="btn secondary" type="submit">Logout</button>
            </form>
          </div>
        </div>

        <% if (error) { %>
          <div class="alert"><%= error %></div>
        <% } %>

        <% if (notice) { %>
          <div class="notice"><%= notice %></div>
        <% } %>

        <div class="summary">
          <p><strong>API Status:</strong> <%= apiConfigured ? 'Configured' : 'Not configured' %></p>
          <p><strong>Last Sync:</strong> <%= supervisorsLastSyncedAt ? formatDate(supervisorsLastSyncedAt) : 'No sync recorded yet' %></p>
          <p><strong>Supervisor Records:</strong> <%= supervisors.length %></p>
          <p><strong>Assigned Students:</strong> <%= assignedApplications.length %></p>
        </div>

        <div class="actions">
          <form action="/hr/supervisors/sync" method="post">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <button class="btn" type="submit">Sync Supervisors From HR API</button>
          </form>
          <a class="btn secondary" href="/hr/supervisors/assignments.csv">Download Assignment CSV</a>
        </div>

        <% if (!apiConfigured) { %>
          <p class="muted-note">Add `HR_SUPERVISOR_API_URL` and the related token settings in the environment before using live supervisor sync.</p>
        <% } %>

        <h2>Supervisor Directory</h2>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Name</th>
                <th>Employee Number</th>
                <th>Department</th>
                <th>Job Title</th>
                <th>Work Station</th>
                <th>Email</th>
                <th>Phone</th>
                <th class="table-count-cell">Assigned Students</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (!supervisors.length) { %>
                <tr>
                  <td class="table-empty-state" colspan="9"><strong>No supervisors are loaded yet.</strong> Sync the HR directory or create a supervisor manually.</td>
                </tr>
              <% } %>

              <% supervisors.forEach((supervisor) => { %>
                <tr>
                  <td>
                    <strong><%= supervisor.fullName %></strong>
                    <div class="muted-note">
                      <%= supervisor.source === 'manual' ? 'Manually created' : 'API synced' %>
                    </div>
                    <% if (!supervisor.canSupervise || !supervisor.isActive) { %>
                      <div class="badge <%= !supervisor.isActive ? 'rejected' : 'warning' %>" style="display: inline-block; margin-top: 0.25rem; font-size: 0.75rem;">
                        <%= !supervisor.isActive ? 'Inactive' : 'Unavailable' %>
                      </div>
                    <% } %>
                  </td>
                  <td><%= supervisor.employeeNumber || 'Not recorded' %></td>
                  <td><%= supervisor.department ? getDepartmentLabel(supervisor.department) : 'Any department' %></td>
                  <td><%= supervisor.jobTitle || 'Not recorded' %></td>
                  <td><%= supervisor.workStation || 'Not recorded' %></td>
                  <td><%= supervisor.email || 'Not recorded' %></td>
                  <td><%= supervisor.phone || 'Not recorded' %></td>
                  <td class="table-count-cell"><%= supervisor.assignedStudents %></td>
                  <td class="table-action-cell" style="white-space: nowrap;">
                    <div style="display: flex; gap: 0.5rem; align-items: center;">
                      <button type="button" class="link-btn edit-btn"
                        data-id="<%= supervisor.supervisorId %>"
                        data-fullname="<%= supervisor.fullName %>"
                        data-employeenumber="<%= supervisor.employeeNumber || '' %>"
                        data-jobtitle="<%= supervisor.jobTitle || '' %>"
                        data-workstation="<%= supervisor.workStation || '' %>"
                        data-email="<%= supervisor.email || '' %>"
                        data-phone="<%= supervisor.phone || '' %>"
                        data-department="<%= supervisor.department || '' %>"
                        data-maxstudents="<%= supervisor.maxStudents || 5 %>">
                        Edit
                      </button>
                      <span class="muted-note">|</span>
                      <form action="/hr/supervisors/<%= supervisor.supervisorId %>/toggle-active" method="post" style="display:inline; margin:0;">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                        <button type="submit" class="link-btn">
                          <%= supervisor.isActive ? 'Deactivate' : 'Activate' %>
                        </button>
                      </form>
                      <% if (supervisor.source === 'manual') { %>
                        <span class="muted-note">|</span>
                        <form action="/hr/supervisors/<%= supervisor.supervisorId %>/delete" method="post" style="display:inline; margin:0;" onsubmit="return confirm('Are you sure you want to delete <%= supervisor.fullName %>? This will clear their assignment profile.');">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                          <button type="submit" class="link-btn danger-text">Delete</button>
                        </form>
                      <% } %>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>

      <!-- Edit Supervisor Form (hidden by default) -->
      <section class="card" id="edit-supervisor-section" style="display: none; border: 1px solid var(--primary-light);">
        <h2>Edit Supervisor Profile</h2>
        <form id="edit-supervisor-form" action="" method="post" class="form-grid">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          
          <label>
            Full Name *
            <input type="text" name="fullName" id="edit-fullName" required />
          </label>
          
          <label>
            Employee Number
            <input type="text" name="employeeNumber" id="edit-employeeNumber" placeholder="e.g. UGC-HR-002" />
          </label>

          <label>
            Job Title
            <input type="text" name="jobTitle" id="edit-jobTitle" placeholder="e.g. Senior Officer" />
          </label>

          <label>
            Work Station
            <input type="text" name="workStation" id="edit-workStation" placeholder="e.g. HQ Block B" />
          </label>

          <label>
            Email Address
            <input type="email" name="email" id="edit-email" placeholder="e.g. officer@uasingishu.go.ke" />
          </label>

          <label>
            Phone Number
            <input type="tel" name="phone" id="edit-phone" placeholder="e.g. 0700000000" />
          </label>

          <label>
            Department
            <select name="department" id="edit-department">
              <option value="">Any / All Departments</option>
              <% departments.forEach((dept) => { %>
                <option value="<%= dept.key %>"><%= dept.label %></option>
              <% }) %>
            </select>
          </label>

          <label>
            Max Students Capacity
            <input type="number" name="maxStudents" id="edit-maxStudents" min="1" max="100" required />
          </label>

          <div class="actions full-width" style="margin-top: 1rem;">
            <button class="btn" type="submit">Save Changes</button>
            <button class="btn secondary" type="button" onclick="cancelEdit()">Cancel</button>
          </div>
        </form>
      </section>

      <!-- Create Supervisor Form -->
      <section class="card">
        <h2>Add Manual Supervisor Profile</h2>
        <p class="muted-note">Use this form to add supervisors manually when they are not available via automatic HR API synchronization.</p>
        <form action="/hr/supervisors/create" method="post" class="form-grid">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          
          <label>
            Full Name *
            <input type="text" name="fullName" required placeholder="e.g. Dr. John Kiprop" />
          </label>
          
          <label>
            Employee Number
            <input type="text" name="employeeNumber" placeholder="e.g. UGC-HR-005" />
          </label>

          <label>
            Job Title
            <input type="text" name="jobTitle" placeholder="e.g. Chief ICT Officer" />
          </label>

          <label>
            Work Station
            <input type="text" name="workStation" placeholder="e.g. County HQ" />
          </label>

          <label>
            Email Address
            <input type="email" name="email" placeholder="e.g. john.kiprop@uasingishu.go.ke" />
          </label>

          <label>
            Phone Number
            <input type="tel" name="phone" placeholder="e.g. 0722000000" />
          </label>

          <label>
            Department
            <select name="department">
              <option value="">Any / All Departments</option>
              <% departments.forEach((dept) => { %>
                <option value="<%= dept.key %>"><%= dept.label %></option>
              <% }) %>
            </select>
          </label>

          <label>
            Max Students Capacity
            <input type="number" name="maxStudents" min="1" max="100" value="5" required />
          </label>

          <div class="actions full-width" style="margin-top: 1rem;">
            <button class="btn" type="submit">Create Supervisor Profile</button>
          </div>
        </form>
      </section>

      <section class="card">
        <h2>Current Student Assignments</h2>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Tracking Number</th>
                <th>Student</th>
                <th>Institution</th>
                <th>Department</th>
                <th>Period</th>
                <th>Supervisor</th>
                <th>Assigned At</th>
                <th class="table-action-cell">Action</th>
              </tr>
            </thead>
            <tbody>
              <% if (!assignedApplications.length) { %>
                <tr>
                  <td class="table-empty-state" colspan="8"><strong>No students have been assigned supervisors yet.</strong> Admit a student, then assign a supervisor from the HR application detail page.</td>
                </tr>
              <% } %>

              <% assignedApplications.forEach((application) => { %>
                <tr>
                  <td><%= application.placementNumber || application.id %></td>
                  <td><%= application.fullName %></td>
                  <td><%= application.institution || 'Not recorded' %></td>
                  <td><%= application.appliedDepartment ? getDepartmentLabel(application.appliedDepartment) : 'Not set' %></td>
                  <td><%= application.period ? getPeriodLabel(application.period) : 'Not set' %></td>
                  <td>
                    <strong><%= application.supervisorAssignment.fullName %></strong>
                    <div class="muted-note">
                      <%= application.supervisorAssignment.employeeNumber || 'No employee number' %>
                      <% if (application.supervisorAssignment.workStation) { %>
                        - <%= application.supervisorAssignment.workStation %>
                      <% } %>
                    </div>
                  </td>
                  <td><%= formatDate(application.supervisorAssignment.assignedAt) %></td>
                  <td class="table-action-cell"><a href="/hr/applications/<%= application.id %>">Review</a></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>
    </main>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.edit-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const editSection = document.getElementById('edit-supervisor-section');
        editSection.style.display = 'block';
        
        const supervisorId = btn.getAttribute('data-id');
        const editForm = document.getElementById('edit-supervisor-form');
        editForm.action = '/hr/supervisors/' + supervisorId + '/edit';
        
        document.getElementById('edit-fullName').value = btn.getAttribute('data-fullname') || '';
        document.getElementById('edit-employeeNumber').value = btn.getAttribute('data-employeenumber') || '';
        document.getElementById('edit-jobTitle').value = btn.getAttribute('data-jobtitle') || '';
        document.getElementById('edit-workStation').value = btn.getAttribute('data-workstation') || '';
        document.getElementById('edit-email').value = btn.getAttribute('data-email') || '';
        document.getElementById('edit-phone').value = btn.getAttribute('data-phone') || '';
        document.getElementById('edit-department').value = btn.getAttribute('data-department') || '';
        document.getElementById('edit-maxStudents').value = btn.getAttribute('data-maxstudents') || 5;
        
        editSection.scrollIntoView({ behavior: 'smooth' });
      });
    });
  });

  function cancelEdit() {
    const editSection = document.getElementById('edit-supervisor-section');
    editSection.style.display = 'none';
  }
</script>
<%- include("partials/layout-close") %>

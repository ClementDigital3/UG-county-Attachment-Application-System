      <footer class="site-footer">
        <div class="site-footer-inner">
          <div class="site-footer-main">
            <a class="site-footer-brand" href="/">
              <span class="site-footer-logo-wrap">
                <img
                  class="site-footer-logo"
                  src="/uasin-gishu-logo.jpg"
                  alt="County Government of Uasin Gishu logo"
                  onerror="this.onerror=null;this.src='/uasin-gishu-logo.svg';"
                />
              </span>
              <span class="site-footer-brand-copy">
                <span class="site-footer-kicker">County Government of Uasin Gishu</span>
                <strong class="site-footer-title">Attachment Application Portal</strong>
                <span class="site-footer-copy">
                  Student attachment intake, departmental review, HR clearance, and final follow-up in
                  one county system.
                </span>
              </span>
            </a>

            <div class="site-footer-side">
              <div class="site-footer-motto">The Champions</div>
              <nav class="site-footer-links" aria-label="Footer quick links">
                <a href="/">Home</a>
                <a href="/apply">Apply</a>
                <a href="/track">Track Application</a>
                <a href="<%= adminPortalPath || '/staff-portal' %>">Admin Portal</a>
                <a href="<%= hrPortalPath || '/hr-portal' %>">HR Portal</a>
              </nav>
              <div class="site-footer-meta">
                <span>Eldoret, Kenya</span>
                <a
                  href="https://mail.google.com/mail/?view=cm&fs=1&to=info@uasingishu.go.ke&su=County%20Attachment%20Portal%20Inquiry"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  info@uasingishu.go.ke
                </a>
                <span>05320160000</span>
              </div>
            </div>
          </div>

          <div class="site-footer-bottom">
            <span>&copy; <%= new Date().getFullYear() %> County Government of Uasin Gishu</span>
            <span>
              Managed and maintained by
              <a
                class="site-footer-dev-link"
                href="https://wa.me/254746195839"
                target="_blank"
                rel="noopener noreferrer"
              >
                DevClaud
              </a>
            </span>
          </div>
        </div>
      </footer>

    </div>
    <script>
      (() => {
        const root = document.documentElement;
        const storageKey = "portal-theme";
        const header = document.querySelector(".site-header");
        const button = document.getElementById("themeToggle");
        const text = document.getElementById("themeToggleText");

        function getTheme() {
          return root.getAttribute("data-theme") || "light";
        }

        function applyTheme(theme) {
          root.setAttribute("data-theme", theme);
          localStorage.setItem(storageKey, theme);
          const nextMode = theme === "dark" ? "Light mode" : "Dark mode";
          if (text) {
            text.textContent = nextMode;
          }
          if (button) {
            button.setAttribute("aria-label", `Switch to ${nextMode.toLowerCase()}`);
            button.setAttribute("title", `Switch to ${nextMode.toLowerCase()}`);
          }
        }

        function syncHeaderState() {
          if (!header) {
            return;
          }

          header.classList.toggle("scrolled", window.scrollY > 10);
        }

        function formatCountdown(remainingMs) {
          if (remainingMs <= 0) {
            return {
              days: "00",
              hours: "00",
              minutes: "00",
              seconds: "00"
            };
          }

          const totalSeconds = Math.floor(remainingMs / 1000);
          const days = Math.floor(totalSeconds / 86400);
          const hours = Math.floor((totalSeconds % 86400) / 3600);
          const minutes = Math.floor((totalSeconds % 3600) / 60);
          const seconds = totalSeconds % 60;

          return {
            days: String(days).padStart(2, "0"),
            hours: String(hours).padStart(2, "0"),
            minutes: String(minutes).padStart(2, "0"),
            seconds: String(seconds).padStart(2, "0")
          };
        }

        function syncCountdowns() {
          document.querySelectorAll("[data-countdown-deadline]").forEach((countdown) => {
            const hint = countdown.querySelector("[data-countdown-hint]");
            const days = countdown.querySelector("[data-countdown-days]");
            const hours = countdown.querySelector("[data-countdown-hours]");
            const minutes = countdown.querySelector("[data-countdown-minutes]");
            const seconds = countdown.querySelector("[data-countdown-seconds]");
            const deadlineIso = countdown.dataset.countdownDeadline;
            const deadlineLabel = countdown.dataset.deadlineLabel || "To be announced";

            if (!deadlineIso) {
              [days, hours, minutes, seconds].forEach((node) => {
                if (node) {
                  node.textContent = "--";
                }
              });
              if (hint) {
                hint.textContent = "To be announced";
              }
              return;
            }

            const deadlineTime = Date.parse(deadlineIso);
            if (Number.isNaN(deadlineTime)) {
              [days, hours, minutes, seconds].forEach((node) => {
                if (node) {
                  node.textContent = "--";
                }
              });
              if (hint) {
                hint.textContent = "To be announced";
              }
              return;
            }

            const remainingMs = deadlineTime - Date.now();
            const countdownParts = formatCountdown(remainingMs);
            if (days) {
              days.textContent = countdownParts.days;
            }
            if (hours) {
              hours.textContent = countdownParts.hours;
            }
            if (minutes) {
              minutes.textContent = countdownParts.minutes;
            }
            if (seconds) {
              seconds.textContent = countdownParts.seconds;
            }
            if (hint) {
              hint.textContent = `Deadline: ${deadlineLabel}`;
            }
          });
        }

        applyTheme(getTheme());
        syncHeaderState();
        syncCountdowns();
        window.addEventListener("scroll", syncHeaderState, { passive: true });
        window.setInterval(syncCountdowns, 1000);
        if (button) {
          button.addEventListener("click", () => {
            const nextTheme = getTheme() === "dark" ? "light" : "dark";
            applyTheme(nextTheme);
          });
        }
      })();
    </script>
  </body>
</html>

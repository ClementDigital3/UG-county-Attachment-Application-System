    <script>
      (() => {
        const root = document.documentElement;
        const storageKey = "portal-theme";
        const header = document.querySelector(".site-header");
        const button = document.getElementById("themeToggle");
        const text = document.getElementById("themeToggleText");

        function getTheme() {
          return root.getAttribute("data-theme") || "light";
        }

        function applyTheme(theme) {
          root.setAttribute("data-theme", theme);
          localStorage.setItem(storageKey, theme);
          const nextMode = theme === "dark" ? "Light mode" : "Dark mode";
          if (text) {
            text.textContent = nextMode;
          }
          if (button) {
            button.setAttribute("aria-label", `Switch to ${nextMode.toLowerCase()}`);
            button.setAttribute("title", `Switch to ${nextMode.toLowerCase()}`);
          }
        }

        function syncHeaderState() {
          if (!header) {
            return;
          }

          header.classList.toggle("scrolled", window.scrollY > 10);
        }

        function formatCountdown(remainingMs) {
          if (remainingMs <= 0) {
            return {
              days: "00",
              hours: "00",
              minutes: "00",
              seconds: "00"
            };
          }

          const totalSeconds = Math.floor(remainingMs / 1000);
          const days = Math.floor(totalSeconds / 86400);
          const hours = Math.floor((totalSeconds % 86400) / 3600);
          const minutes = Math.floor((totalSeconds % 3600) / 60);
          const seconds = totalSeconds % 60;

          return {
            days: String(days).padStart(2, "0"),
            hours: String(hours).padStart(2, "0"),
            minutes: String(minutes).padStart(2, "0"),
            seconds: String(seconds).padStart(2, "0")
          };
        }

        function syncCountdowns() {
          document.querySelectorAll("[data-countdown-deadline]").forEach((countdown) => {
            const hint = countdown.querySelector("[data-countdown-hint]");
            const days = countdown.querySelector("[data-countdown-days]");
            const hours = countdown.querySelector("[data-countdown-hours]");
            const minutes = countdown.querySelector("[data-countdown-minutes]");
            const seconds = countdown.querySelector("[data-countdown-seconds]");
            const deadlineIso = countdown.dataset.countdownDeadline;
            const deadlineLabel = countdown.dataset.deadlineLabel || "To be announced";

            if (!deadlineIso) {
              [days, hours, minutes, seconds].forEach((node) => {
                if (node) {
                  node.textContent = "--";
                }
              });
              if (hint) {
                hint.textContent = "To be announced";
              }
              return;
            }

            const deadlineTime = Date.parse(deadlineIso);
            if (Number.isNaN(deadlineTime)) {
              [days, hours, minutes, seconds].forEach((node) => {
                if (node) {
                  node.textContent = "--";
                }
              });
              if (hint) {
                hint.textContent = "To be announced";
              }
              return;
            }

            const remainingMs = deadlineTime - Date.now();
            const countdownParts = formatCountdown(remainingMs);
            if (days) {
              days.textContent = countdownParts.days;
            }
            if (hours) {
              hours.textContent = countdownParts.hours;
            }
            if (minutes) {
              minutes.textContent = countdownParts.minutes;
            }
            if (seconds) {
              seconds.textContent = countdownParts.seconds;
            }
            if (hint) {
              hint.textContent = `Deadline: ${deadlineLabel}`;
            }
          });
        }

        applyTheme(getTheme());
        syncHeaderState();
        syncCountdowns();
        window.addEventListener("scroll", syncHeaderState, { passive: true });
        window.setInterval(syncCountdowns, 1000);
        if (button) {
          button.addEventListener("click", () => {
            const nextTheme = getTheme() === "dark" ? "light" : "dark";
            applyTheme(nextTheme);
          });
        }
      })();
    </script>
    <% if (footerPortal !== 'hr') { %>
      <script>
        (() => {
          const widget = document.querySelector("[data-portal-assistant]");
          if (!widget) {
            return;
          }

          const toggle = widget.querySelector("[data-portal-assistant-toggle]");
          const panel = document.getElementById("portalAssistantPanel");
          const closeButton = widget.querySelector("[data-portal-assistant-close]");
          const thread = widget.querySelector("[data-portal-assistant-thread]");
          const form = widget.querySelector("[data-portal-assistant-form]");
          const input = widget.querySelector("[data-portal-assistant-input]");
          const sendButton = widget.querySelector("[data-portal-assistant-send]");
          const status = widget.querySelector("[data-portal-assistant-status]");
          const quickPrompts = widget.querySelectorAll("[data-assistant-prompt]");
          const history = [];

          // Dragging logic
          let isDragging = false;
          let hasDragged = false;
          let dragStartY = 0;
          let dragStartTop = 0;

          if (toggle) {
            toggle.style.cursor = "grab";
            toggle.addEventListener("mousedown", startDrag);
            toggle.addEventListener("touchstart", startDrag, { passive: false });
          }

          function startDrag(e) {
            if (window.innerWidth <= 980) {
              return; // Disable dragging on mobile/tablet viewports where the button is a fixed bottom bar
            }
            if (e.target.closest("input") || e.target.closest("button:not([data-portal-assistant-toggle])") || e.target.closest("a")) {
              return;
            }
            hasDragged = false;
            dragStartY = e.type === "touchstart" ? e.touches[0].clientY : e.clientY;
            const rect = toggle.getBoundingClientRect();
            dragStartTop = rect.top;

            document.addEventListener("mousemove", drag);
            document.addEventListener("touchmove", drag, { passive: false });
            document.addEventListener("mouseup", stopDrag);
            document.addEventListener("touchend", stopDrag);
          }

          function drag(e) {
            const clientY = e.type === "touchmove" ? e.touches[0].clientY : e.clientY;
            const deltaY = clientY - dragStartY;
            if (Math.abs(deltaY) > 10) {
              isDragging = true;
              hasDragged = true;
            }
            if (isDragging) {
              e.preventDefault();
              toggle.style.cursor = "grabbing";
              document.body.style.cursor = "grabbing";
              let newTop = dragStartTop + deltaY;
              const toggleHeight = toggle.offsetHeight;
              const maxTop = window.innerHeight - toggleHeight - 16;
              newTop = Math.max(16, Math.min(newTop, maxTop));
              toggle.style.bottom = "auto";
              toggle.style.top = newTop + "px";
            }
          }

          function stopDrag(e) {
            document.removeEventListener("mousemove", drag);
            document.removeEventListener("touchmove", drag);
            document.removeEventListener("mouseup", stopDrag);
            document.removeEventListener("touchend", stopDrag);
            if (toggle) {
              toggle.style.cursor = "grab";
            }
            document.body.style.cursor = "";
            setTimeout(() => {
              isDragging = false;
              hasDragged = false;
            }, 100);
          }

          function setOpen(isOpen) {
            panel.hidden = !isOpen;
            toggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
            if (isOpen) {
              window.setTimeout(() => input && input.focus(), 50);
            }
          }

          function setBusy(isBusy, text) {
            if (sendButton) {
              sendButton.disabled = isBusy;
            }
            if (input) {
              input.disabled = isBusy;
            }
            if (status) {
              status.textContent = text || (isBusy ? "Assistant is thinking..." : "County assistant ready.");
            }
          }

          function appendBubble(role, text) {
            const bubble = document.createElement("article");
            bubble.className = `portal-assistant-bubble ${role === "user" ? "is-user" : "is-assistant"}`;
            bubble.textContent = text;
            thread.appendChild(bubble);
            thread.scrollTop = thread.scrollHeight;
          }

          async function sendMessage(message) {
            const trimmed = (message || "").trim();
            if (!trimmed) {
              return;
            }

            setOpen(true);
            appendBubble("user", trimmed);
            history.push({ role: "user", content: trimmed });
            if (history.length > 6) {
              history.splice(0, history.length - 6);
            }
            if (input) {
              input.value = "";
            }
            setBusy(true, "Assistant is thinking...");
            try {
              const csrfMeta = document.querySelector('meta[name="csrf-token"]');
              const csrfToken = csrfMeta ? csrfMeta.getAttribute("content") : "";

              const response = await fetch("/api/assistant/chat", {
                method: "POST",
                headers: {
                  "Content-Type": "application/json",
                  "X-CSRF-Token": csrfToken
                },
                body: JSON.stringify({
                  message: trimmed,
                  history,
                  pageContext: `${document.body.dataset.portal || "public"}:${window.location.pathname}`
                })
              });

              const payload = await response.json().catch(() => ({}));
              if (!response.ok) {
                throw new Error(payload.error || "Assistant request failed.");
              }

              const reply = (payload.reply || "").toString().trim() || "I could not prepare an answer right now.";
              appendBubble("assistant", reply);
              history.push({ role: "assistant", content: reply });
              if (history.length > 6) {
                history.splice(0, history.length - 6);
              }
              setBusy(false, payload.provider === "openai" ? "Live AI response complete." : "Fallback portal guidance used.");
            } catch (error) {
              appendBubble("assistant", error.message || "The assistant is unavailable right now. Please try again shortly.");
              setBusy(false, "Assistant unavailable right now.");
            }
          }

          if (toggle) {
            toggle.addEventListener("click", (e) => {
              if (hasDragged) {
                hasDragged = false;
                e.preventDefault();
                e.stopPropagation();
                return;
              }
              setOpen(panel.hidden);
            });
          }
          if (closeButton) {
            closeButton.addEventListener("click", () => setOpen(false));
          }
          if (form) {
            form.addEventListener("submit", (event) => {
              event.preventDefault();
              sendMessage(input ? input.value : "");
            });
          }
          if (input) {
            input.addEventListener("keydown", (event) => {
              if (event.key === "Enter" && !event.shiftKey) {
                event.preventDefault();
                sendMessage(input.value);
              }
            });
          }
          quickPrompts.forEach((button) => {
            button.addEventListener("click", () => sendMessage(button.dataset.assistantPrompt || ""));
          });
        })();
      </script>
    <% } %>

    <% if (footerPortal !== 'hr') { %>
      <!-- Cookie Consent Banner -->
      <div id="cookieConsentBanner" class="cookie-consent-banner" hidden>
        <div class="cookie-consent-content">
          <div class="cookie-consent-icon">
            <svg viewBox="0 0 24 24" width="24" height="24">
              <path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zm1.5 13.5a1.5 1.5 0 1 1-1.5-1.5 1.5 1.5 0 0 1 1.5 1.5zm0-4a1.5 1.5 0 1 1-1.5-1.5 1.5 1.5 0 0 1 1.5 1.5zM12 8a1.5 1.5 0 1 1 1.5-1.5A1.5 1.5 0 0 1 12 8z" fill="currentColor"/>
            </svg>
          </div>
          <div class="cookie-consent-text">
            <h4>Cookie & Privacy Consent</h4>
            <p>This portal uses essential session cookies to authenticate your session and protect against CSRF security threats. By continuing, you agree to our privacy policy.</p>
          </div>
        </div>
        <div class="cookie-consent-actions">
          <button id="btnAcceptCookies" class="btn btn-sm">Accept Cookies</button>
          <button id="btnRejectCookies" class="btn btn-sm secondary">Decline</button>
          <button id="btnLaterCookies" class="btn btn-sm text">Later</button>
        </div>
      </div>
      
      <style>
        .cookie-consent-banner {
          position: fixed;
          bottom: 24px;
          left: 50%;
          transform: translateX(-50%) translateY(100px);
          width: 90%;
          max-width: 650px;
          background: rgba(var(--card-bg-rgb, 255, 255, 255), 0.85);
          backdrop-filter: blur(16px);
          -webkit-backdrop-filter: blur(16px);
          border: 1px solid rgba(var(--border-rgb, 0, 0, 0), 0.1);
          border-radius: 16px;
          box-shadow: 0 12px 40px rgba(0, 0, 0, 0.15);
          padding: 20px 24px;
          display: flex;
          flex-direction: row;
          justify-content: space-between;
          align-items: center;
          gap: 24px;
          z-index: 10000;
          opacity: 0;
          transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.5s ease;
        }
        .cookie-consent-banner.show {
          transform: translateX(-50%) translateY(0);
          opacity: 1;
        }
        .cookie-consent-content {
          display: flex;
          gap: 16px;
          align-items: flex-start;
        }
        .cookie-consent-icon {
          color: var(--primary-color, #1e5631);
          margin-top: 4px;
          flex-shrink: 0;
        }
        .cookie-consent-text h4 {
          margin: 0 0 4px 0;
          font-size: 1.05rem;
          font-weight: 700;
          color: var(--text-color, #1a1a1a);
        }
        .cookie-consent-text p {
          margin: 0;
          font-size: 0.85rem;
          line-height: 1.4;
          color: var(--text-muted, #666);
        }
        .cookie-consent-actions {
          display: flex;
          gap: 10px;
          flex-shrink: 0;
        }
        .cookie-consent-actions .btn {
          padding: 8px 16px;
          font-size: 0.85rem;
          border-radius: 8px;
          cursor: pointer;
        }
        .cookie-consent-actions .btn.secondary {
          background: rgba(var(--border-rgb, 0, 0, 0), 0.05);
          color: var(--text-color, #1a1a1a);
          border: 1px solid rgba(var(--border-rgb, 0, 0, 0), 0.1);
        }
        .cookie-consent-actions .btn.text {
          background: transparent;
          border: none;
          color: var(--text-muted, #666);
        }
        .cookie-consent-actions .btn.text:hover {
          color: var(--text-color, #1a1a1a);
        }
        @media (max-width: 600px) {
          .cookie-consent-banner {
            flex-direction: column;
            align-items: stretch;
            bottom: 16px;
            padding: 16px;
            gap: 16px;
          }
          .cookie-consent-actions {
            justify-content: flex-end;
          }
        }
      </style>
      
      <script>
        (() => {
          const banner = document.getElementById('cookieConsentBanner');
          const acceptBtn = document.getElementById('btnAcceptCookies');
          const rejectBtn = document.getElementById('btnRejectCookies');
          const laterBtn = document.getElementById('btnLaterCookies');
          const storageKey = 'ugc-cookie-consent';
          
          const consent = localStorage.getItem(storageKey);
          if (!consent) {
            // Show banner after 1.5 seconds
            setTimeout(() => {
              banner.removeAttribute('hidden');
              // Force layout reflow
              banner.offsetHeight;
              banner.classList.add('show');
            }, 1500);
          }
          
          function hideBanner() {
            banner.classList.remove('show');
            setTimeout(() => {
              banner.setAttribute('hidden', '');
            }, 500);
          }
          
          acceptBtn.addEventListener('click', () => {
            localStorage.setItem(storageKey, 'accepted');
            hideBanner();
          });
          
          rejectBtn.addEventListener('click', () => {
            localStorage.setItem(storageKey, 'declined');
            hideBanner();
          });
          
          laterBtn.addEventListener('click', () => {
            hideBanner();
          });
        })();
      </script>
    <% } %>
  </body>
</html>


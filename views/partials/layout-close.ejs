              <img class="portal-assistant-avatar" src="/county-assistant-lady.svg" alt="" />
            </span>
            <span class="portal-assistant-toggle-copy">
              <span class="portal-assistant-toggle-kicker">AI Help</span>
              <strong>Ask County Assistant</strong>
            </span>
          </button>

          <section
            id="portalAssistantPanel"
            class="portal-assistant-panel"
            hidden
            aria-label="County portal assistant"
          >
            <div class="portal-assistant-panel-head">
              <div class="portal-assistant-panel-title">
                <span class="portal-assistant-panel-avatar-wrap" aria-hidden="true">
                  <img class="portal-assistant-panel-avatar" src="/county-assistant-lady.svg" alt="" />
                </span>
                <div>
                  <span class="portal-assistant-panel-kicker">County Portal Guide</span>
                  <h2>Attachment Help Assistant</h2>
                </div>
              </div>
              <button class="portal-assistant-close" type="button" data-portal-assistant-close aria-label="Close assistant">
                &times;
              </button>
            </div>


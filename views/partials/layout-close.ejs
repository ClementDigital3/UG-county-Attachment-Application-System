      <footer class="site-footer">
        <div class="site-footer-inner">
          <span>County Government of Uasin Gishu</span>
          <span>Attachment Application Portal</span>
          <span>&copy; <%= new Date().getFullYear() %></span>
        </div>
      </footer>

      <button
        id="themeToggle"
        class="theme-toggle"
        type="button"
        aria-label="Switch theme"
        title="Switch theme"
      >
        <span class="theme-toggle-icon theme-toggle-icon-sun" aria-hidden="true">
          <svg viewBox="0 0 24 24" focusable="false">
            <path
              d="M12 4V2m0 20v-2m8-8h2M2 12h2m12.66 5.66 1.41 1.41M3.93 4.93l1.41 1.41m11.32-1.41 1.41-1.41M3.93 19.07l1.41-1.41M12 7a5 5 0 1 0 0 10 5 5 0 0 0 0-10Z"
              fill="none"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.8"
            />
          </svg>
        </span>
        <span class="theme-toggle-icon theme-toggle-icon-moon" aria-hidden="true">
          <svg viewBox="0 0 24 24" focusable="false">
            <path
              d="M20 15.79A8.5 8.5 0 0 1 8.21 4c-.13.47-.21.97-.21 1.5a8.5 8.5 0 0 0 10.5 8.29c.53 0 1.03-.08 1.5-.21Z"
              fill="none"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.8"
            />
          </svg>
        </span>
        <span id="themeToggleText" class="theme-toggle-text">Dark mode</span>
      </button>
    </div>
    <script>
      (() => {
        const root = document.documentElement;
        const storageKey = "portal-theme";
        const button = document.getElementById("themeToggle");
        const text = document.getElementById("themeToggleText");

        if (!button || !text) {
          return;
        }

        function getTheme() {
          return root.getAttribute("data-theme") || "light";
        }

        function applyTheme(theme) {
          root.setAttribute("data-theme", theme);
          localStorage.setItem(storageKey, theme);
          const nextMode = theme === "dark" ? "Light mode" : "Dark mode";
          text.textContent = nextMode;
          button.setAttribute("aria-label", `Switch to ${nextMode.toLowerCase()}`);
          button.setAttribute("title", `Switch to ${nextMode.toLowerCase()}`);
        }

        button.addEventListener("click", () => {
          const nextTheme = getTheme() === "dark" ? "light" : "dark";
          applyTheme(nextTheme);
        });

        applyTheme(getTheme());
      })();
    </script>
  </body>
</html>

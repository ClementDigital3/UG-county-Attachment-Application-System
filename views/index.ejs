<%- include("partials/layout-open", { pageTitle: "County Attachment Portal", activePortal: "home" }) %>
<main class="container wide landing-page">
      <section class="landing-runner <%= landingRunner.isOpen ? 'is-open' : 'is-closed' %>">
        <div class="landing-runner-box">
          <div class="landing-runner-copy">
            <span class="landing-runner-label">Live window</span>
            <div class="landing-runner-track" aria-label="Attachment application announcement">
              <div class="landing-runner-text">
                <span><%= landingRunner.message %></span>
                <span>Open windows: <%= landingRunner.openPeriodText %></span>
                <span>Deadline: <%= landingRunner.deadlineLabel %></span>
                <span><%= landingRunner.message %></span>
                <span>Open windows: <%= landingRunner.openPeriodText %></span>
                <span>Deadline: <%= landingRunner.deadlineLabel %></span>
              </div>
            </div>
          </div>

          <div class="landing-runner-actions">
            <div
              class="landing-runner-deadline"
              data-countdown-deadline="<%= landingRunner.deadlineIso %>"
              data-deadline-label="<%= landingRunner.deadlineLabel %>"
            >
              <span>Time left</span>
              <div class="landing-countdown" data-countdown-grid>
                <div class="landing-countdown-segment">
                  <strong data-countdown-days>--</strong>
                  <small>Days</small>
                </div>
                <div class="landing-countdown-segment">
                  <strong data-countdown-hours>--</strong>
                  <small>Hours</small>
                </div>
                <div class="landing-countdown-segment">
                  <strong data-countdown-minutes>--</strong>
                  <small>Minutes</small>
                </div>
                <div class="landing-countdown-segment">
                  <strong data-countdown-seconds>--</strong>
                  <small>Seconds</small>
                </div>
              </div>
              <small data-countdown-hint>
                <%= landingRunner.hasCountdown ? `Deadline: ${landingRunner.deadlineLabel}` : 'To be announced' %>
              </small>
            </div>
            <span class="landing-runner-tag">
              <span class="landing-runner-tag-dot"></span>
              <%= landingRunner.isOpen ? 'Applications open' : 'Applications closed' %>
            </span>
          </div>
        </div>
      </section>

      <section class="landing-hero-grid">
        <section class="card landing-hero-panel">
          <p class="eyebrow">County Attachment Offer</p>
          <h1>Attachment placement for students seeking practical service experience in Uasin Gishu County.</h1>
          <p class="landing-lead">
            Apply during the open county window, upload your documents in the right format, and follow your progress up to the final joining letter.
          </p>

          <div class="actions">
            <a class="btn" href="/apply">Start Application</a>
            <a class="btn secondary" href="/track">Track Application</a>
          </div>

          <div class="landing-stat-grid">
            <div>
              <strong><%= openPeriodOptions.length %></strong>
              <span>Open windows</span>
            </div>
            <div>
              <strong><%= remainingApplicants %></strong>
              <span>Remaining slots</span>
            </div>
            <div>
              <strong><%= pending %></strong>
              <span>Pending review</span>
            </div>
            <div>
              <strong><%= total %></strong>
              <span>Total applications</span>
            </div>
          </div>
        </section>

        <aside class="card landing-illustration-panel">
          <p class="eyebrow">Quick Guide</p>
          <div class="landing-illustration">
            <div class="illustration-badge">01</div>
            <div class="illustration-card">
              <strong>Apply only in an open quarter</strong>
              <span>Watch the live runner for the current county window and deadline.</span>
            </div>
            <div class="illustration-line"></div>
            <div class="illustration-badge">02</div>
            <div class="illustration-card">
              <strong>Prepare the right uploads</strong>
              <span>Use one combined document for the main documents and a separate NITA document.</span>
            </div>
            <div class="illustration-line"></div>
            <div class="illustration-badge">03</div>
            <div class="illustration-card">
              <strong>Follow review to final letter</strong>
              <span>Track department review, NITA return, HR approval, and joining letter download from one dashboard.</span>
            </div>
          </div>
        </aside>
      </section>

      <section class="card landing-window-panel">
        <div class="row-between">
          <div>
            <p class="eyebrow">Attachment Windows</p>
            <h2>Four county application quarters each year</h2>
          </div>
          <div class="landing-window-status">
            <span class="landing-window-status-dot"></span>
            <span><%= openPeriodOptions.length ? 'Open' : 'Closed' %></span>
          </div>
        </div>

        <div class="landing-window-grid">
          <% periodOptions.forEach((period) => { %>
            <article class="landing-window-card <%= period.isOpen ? 'is-open' : 'is-closed' %>">
              <strong><%= period.shortLabel || period.label %></strong>
              <span><%= period.isOpen ? 'Applications are ongoing' : 'Closed until HR opens this quarter' %></span>
            </article>
          <% }) %>
        </div>
      </section>

      <section class="landing-bottom-grid">
        <section class="card landing-brief-card landing-checklist-card">
          <p class="eyebrow">Student Checklist</p>
          <h2>Before you click apply</h2>
          <ul class="landing-checklist">
            <li>Choose the department first for fair departmental institution distribution.</li>
            <li>Prepare the combined scanned document.</li>
            <li>Upload the NITA document separately.</li>
            <li>Keep your tracking number for follow-up.</li>
          </ul>
        </section>

        <section class="card landing-brief-card landing-distribution-box">
          <div class="row-between">
            <div>
              <p class="eyebrow">Department Fair Limits</p>
              <h2>Per-institution intake</h2>
            </div>
          </div>
          <p class="landing-brief-copy">
            Scroll through all departments to see the number of slots one institution can use in each department.
          </p>
          <div class="landing-scroll-list">
            <% if (institutionDepartmentLimits && institutionDepartmentLimits.length) { %>
              <% institutionDepartmentLimits.forEach((department) => { %>
                <div class="landing-scroll-item">
                  <div>
                    <strong><%= department.label %></strong>
                    <span><%= department.capacity %> total department slots</span>
                  </div>
                  <div class="landing-scroll-metric">
                    <strong><%= department.institutionLimit %></strong>
                    <span>per institution</span>
                  </div>
                </div>
              <% }) %>
            <% } else { %>
              <div class="landing-scroll-item">
                <div>
                  <strong>No capacities configured yet</strong>
                  <span>HR can set departmental limits from the HR portal.</span>
                </div>
              </div>
            <% } %>
          </div>
        </section>
      </section>
    </main>
<%- include("partials/layout-close") %>

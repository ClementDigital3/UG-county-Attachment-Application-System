<%- include("partials/layout-open", { pageTitle: "County Attachment Portal", activePortal: "home" }) %>
<main class="container">
      <section class="card hero">
        <h1>County Attachment Application Portal</h1>
        <p>
          Student applications are accepted only during open county attachment windows.
          Admin staff control which period is open.
        </p>
        <div class="stats">
          <div>
            <strong><%= total %></strong>
            <span>Total applications</span>
          </div>
          <div>
            <strong><%= pending %></strong>
            <span>Pending review</span>
          </div>
          <% if (remainingApplicants !== null) { %>
            <div>
              <strong><%= remainingApplicants %></strong>
              <span>Remaining slots</span>
            </div>
          <% } %>
          <div>
            <strong><%= openPeriodOptions.length %></strong>
            <span>Open periods</span>
          </div>
        </div>
        <% if (remainingApplicants !== null) { %>
          <p>Intake capacity: <strong><%= maxApplicants %></strong> applicants.</p>
        <% } %>
      </section>

      <section class="card">
        <h2>Attachment Period Windows</h2>
        <p>County attachment runs in three windows per year.</p>
        <div class="period-chip-wrap">
          <% periodOptions.forEach((period) => { %>
            <span class="period-chip <%= period.isOpen ? 'open' : 'closed' %>">
              <%= period.label %> - <%= period.isOpen ? 'Open' : 'Closed' %>
            </span>
          <% }) %>
        </div>
      </section>

      <section class="card">
        <h2>Institution Distribution</h2>
        <div class="summary">
          <p>
            Institution distribution helps the county share attachment opportunities fairly
            across different institutions.
          </p>
          <p>
            It prevents one institution from taking all the slots in the same department and
            helps give students from other institutions a fair chance to apply.
          </p>
          <p>
            Students should enter institution names in full so the system can count each
            institution correctly.
          </p>
        </div>
        <% if (institutionDepartmentLimits && institutionDepartmentLimits.length) { %>
          <div class="stats compact">
            <% institutionDepartmentLimits.forEach((department) => { %>
              <div>
                <strong><%= department.institutionLimit %></strong>
                <span><%= department.label %> per institution</span>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <p>No department slot capacities are configured yet.</p>
        <% } %>
      </section>
    </main>
<%- include("partials/layout-close") %>


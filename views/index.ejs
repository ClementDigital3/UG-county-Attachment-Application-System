<%- include("partials/layout-open", { pageTitle: "County Attachment Portal", activePortal: "home" }) %>
<main class="container wide landing-page">
      <section class="landing-runner <%= landingRunner.isOpen ? 'is-open' : 'is-closed' %>">
        <div class="landing-runner-box">
          <div class="landing-runner-copy">
            <span class="landing-runner-label">Live window</span>
            <div class="landing-runner-track" aria-label="Attachment application announcement">
              <div class="landing-runner-text">
                <span><%= landingRunner.message %></span>
                <span>Open windows: <%= landingRunner.openPeriodText %></span>
                <span>Deadline: <%= landingRunner.deadlineLabel %></span>
                <span><%= landingRunner.message %></span>
                <span>Open windows: <%= landingRunner.openPeriodText %></span>
                <span>Deadline: <%= landingRunner.deadlineLabel %></span>
              </div>
            </div>
          </div>

          <div class="landing-runner-actions">
            <div
              class="landing-runner-deadline"
              data-countdown-deadline="<%= landingRunner.deadlineIso %>"
              data-deadline-label="<%= landingRunner.deadlineLabel %>"
            >
              <span>Time left</span>
              <div class="landing-countdown" data-countdown-grid>
                <div class="landing-countdown-segment">
                  <strong data-countdown-days>--</strong>
                  <small>Days</small>
                </div>
                <div class="landing-countdown-segment">
                  <strong data-countdown-hours>--</strong>
                  <small>Hours</small>
                </div>
                <div class="landing-countdown-segment">
                  <strong data-countdown-minutes>--</strong>
                  <small>Minutes</small>
                </div>
                <div class="landing-countdown-segment">
                  <strong data-countdown-seconds>--</strong>
                  <small>Seconds</small>
                </div>
              </div>
              <small data-countdown-hint>
                <%= landingRunner.deadlineHint %>
              </small>
            </div>
            <span class="landing-runner-tag">
              <span class="landing-runner-tag-dot"></span>
              <%= landingRunner.isOpen ? 'Applications open' : landingRunner.isDeadlineClosed ? 'Closed by deadline' : 'Applications closed' %>
            </span>
          </div>
        </div>
      </section>

      <section class="landing-hero-grid">
        <section class="card landing-hero-panel">
          <p class="eyebrow">County Attachment Offer</p>
          <h1>Attachment placement for students seeking practical service experience in Uasin Gishu County.</h1>
          <p class="landing-lead">
            Apply during the open county window, upload your documents in the right format, and follow your progress up to the final joining letter.
          </p>

          <div class="actions">
            <a class="btn" href="/apply">Start Application</a>
            <a class="btn secondary" href="/track">Track Application</a>
          </div>

          <div class="landing-stat-grid">
            <div>
              <strong><%= openPeriodOptions.length %></strong>
              <span>Open windows</span>
            </div>
            <div>
              <strong><%= remainingApplicants %></strong>
              <span>Remaining slots</span>
            </div>
            <div>
              <strong><%= pending %></strong>
              <span>Pending review</span>
            </div>
            <div>
              <strong><%= total %></strong>
              <span>Total applications</span>
            </div>
          </div>

          <div class="landing-offer-strip" aria-label="County attachment summary">
            <div class="landing-offer-item">
              <strong>County-managed process</strong>
              <span>HR controls the intake window, departmental review access, and the final county admission decision from one portal.</span>
            </div>
            <div class="landing-offer-item">
              <strong>Fair placement rule</strong>
              <span>Department ratios limit how many applicants from one institution can fill the same county department slots.</span>
            </div>
            <div class="landing-offer-item">
              <strong>Student outcome</strong>
              <span>Applicants follow one tracked process from review, to NITA handling, to the final joining letter download.</span>
            </div>
          </div>
        </section>

        <aside class="card landing-illustration-panel">
          <p class="eyebrow">Quick Guide</p>
          <div class="landing-illustration">
            <div class="illustration-badge">01</div>
            <div class="illustration-card">
              <strong>Apply only in an open quarter</strong>
              <span>Watch the live runner for the current county window and deadline.</span>
            </div>
            <div class="illustration-line"></div>
            <div class="illustration-badge">02</div>
            <div class="illustration-card">
              <strong>Prepare the right uploads</strong>
              <span>Use one combined document for the main documents and a separate NITA document.</span>
            </div>
            <div class="illustration-line"></div>
            <div class="illustration-badge">03</div>
            <div class="illustration-card">
              <strong>Follow review to final letter</strong>
              <span>Track department review, NITA return, HR admission, and joining letter download from one dashboard.</span>
            </div>
          </div>
        </aside>
      </section>

      <section class="card landing-window-panel">
        <div class="row-between">
          <div>
            <p class="eyebrow">Attachment Windows</p>
            <h2>Four county application quarters each year</h2>
          </div>
          <div class="landing-window-status">
            <span class="landing-window-status-dot"></span>
            <span><%= openPeriodOptions.length ? 'Open' : 'Closed' %></span>
          </div>
        </div>

        <div class="landing-window-grid">
          <% periodOptions.forEach((period) => { %>
            <article class="landing-window-card <%= period.isOpen ? 'is-open' : 'is-closed' %>">
              <strong><%= period.label %> <%= period.quarterLabel ? `(${period.quarterLabel})` : '' %></strong>
              <span><%= period.publicStatusLabel %></span>
            </article>
          <% }) %>
        </div>
      </section>

      <section class="landing-bottom-grid">
        <section class="card landing-brief-card landing-checklist-card">
          <p class="eyebrow">Student Checklist</p>
          <h2>Before you click apply</h2>
          <ul class="landing-checklist">
            <li>Choose the department first for fair departmental institution distribution.</li>
            <li>Prepare the combined scanned document.</li>
            <li>Upload the NITA document separately.</li>
            <li>Keep your tracking number for follow-up.</li>
          </ul>
        </section>

        <section class="card landing-brief-card landing-distribution-box">
          <div class="row-between">
            <div>
              <p class="eyebrow">Department Fair Limits</p>
              <h2>Per-institution intake</h2>
            </div>
          </div>
          <p class="landing-brief-copy">
            Scroll through all departments to see the number of slots one institution can use in each department.
          </p>
          <div class="landing-scroll-list">
            <% if (institutionDepartmentLimits && institutionDepartmentLimits.length) { %>
              <% institutionDepartmentLimits.forEach((department) => { %>
                <div class="landing-scroll-item">
                  <div>
                    <strong><%= department.label %></strong>
                    <span><%= department.capacity %> total department slots</span>
                  </div>
                  <div class="landing-scroll-metric">
                    <strong><%= department.institutionLimit %></strong>
                    <span>per institution</span>
                  </div>
                </div>
              <% }) %>
            <% } else { %>
              <div class="landing-scroll-item">
                <div>
                  <strong>No capacities configured yet</strong>
                  <span>HR can set departmental limits from the HR portal.</span>
                </div>
              </div>
            <% } %>
          </div>
        </section>
      </section>

      <!-- Testing Feedback Panel -->
      <section class="card landing-window-panel" style="margin-top: 0.85rem;">
        <div class="row-between">
          <div>
            <p class="eyebrow">Testing Feedback</p>
            <h2>Help us improve the system</h2>
          </div>
        </div>
        <p class="landing-brief-copy" style="max-width: 100%; margin-bottom: 1.25rem;">
          If you are testing the attachment portal, please leave your feedback, suggestions, or report any issues below. Your feedback will be directly logged into the system audit trail on the HR portal.
        </p>
        <form id="testingFeedbackForm" class="feedback-form" method="POST" action="/api/testing-feedback" style="max-width: 600px;">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          
          <div class="form-group" style="margin-bottom: 1rem;">
            <label for="feedbackName" style="display: block; font-weight: 600; font-size: 0.85rem; margin-bottom: 0.35rem; color: var(--muted);">Your Name / Organization (Optional)</label>
            <input type="text" id="feedbackName" name="name" placeholder="Anonymous Tester" style="width: 100%; padding: 0.75rem; border-radius: 10px; border: 1px solid var(--border); background: var(--input-bg); color: var(--input-text); font-family: inherit; font-size: 0.9rem;" />
          </div>
          
          <div class="form-group" style="margin-bottom: 1.25rem;">
            <label for="feedbackMessage" style="display: block; font-weight: 600; font-size: 0.85rem; margin-bottom: 0.35rem; color: var(--muted);">Feedback / Bug Reports / Suggestions <span style="color: var(--danger);">*</span></label>
            <textarea id="feedbackMessage" name="message" rows="4" required placeholder="Type your observations, suggestions, or bugs here..." style="width: 100%; padding: 0.75rem; border-radius: 10px; border: 1px solid var(--border); background: var(--input-bg); color: var(--input-text); font-family: inherit; font-size: 0.9rem; resize: vertical;"></textarea>
          </div>
          
          <button type="submit" id="submitFeedbackBtn" class="btn" style="padding: 0.7rem 1.5rem; display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem;">
            Submit Feedback
          </button>
        </form>
        <div id="feedbackResponseMsg" style="margin-top: 1rem; padding: 0.75rem; border-radius: 8px; font-size: 0.9rem; font-weight: 600; display: none;"></div>
      </section>

      <script>
        document.addEventListener("DOMContentLoaded", () => {
          const form = document.getElementById("testingFeedbackForm");
          const nameInput = document.getElementById("feedbackName");
          const msgInput = document.getElementById("feedbackMessage");
          const submitBtn = document.getElementById("submitFeedbackBtn");
          const responseDiv = document.getElementById("feedbackResponseMsg");

          if (form) {
            form.addEventListener("submit", async (e) => {
              e.preventDefault();

              submitBtn.disabled = true;
              submitBtn.textContent = "Submitting...";
              responseDiv.style.display = "none";

              try {
                const response = await fetch("/api/testing-feedback", {
                  method: "POST",
                  headers: {
                    "Content-Type": "application/json"
                  },
                  body: JSON.stringify({
                    _csrf: form.querySelector('input[name="_csrf"]').value,
                    name: nameInput.value,
                    message: msgInput.value
                  })
                });

                const data = await response.json();
                if (response.ok && data.success) {
                  responseDiv.style.display = "block";
                  responseDiv.style.backgroundColor = "rgba(31, 125, 66, 0.1)";
                  responseDiv.style.color = "var(--success)";
                  responseDiv.style.border = "1px solid var(--success)";
                  responseDiv.textContent = data.message;
                  form.reset();
                } else {
                  throw new Error(data.error || "An error occurred while submitting feedback.");
                }
              } catch (err) {
                responseDiv.style.display = "block";
                responseDiv.style.backgroundColor = "rgba(180, 35, 24, 0.1)";
                responseDiv.style.color = "var(--danger)";
                responseDiv.style.border = "1px solid var(--danger)";
                responseDiv.textContent = err.message || "Failed to submit feedback. Please try again.";
              } finally {
                submitBtn.disabled = false;
                submitBtn.textContent = "Submit Feedback";
              }
            });
          }
        });
      </script>
    </main>
<%- include("partials/layout-close") %>


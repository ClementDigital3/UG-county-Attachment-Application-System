<%- include("partials/layout-open", { pageTitle: "HR Applications Queue", activePortal: "hr" }) %>
<main class="container wide">
      <section class="card">
        <div class="row-between">
          <h1>HR Applications Queue</h1>
          <div class="actions tight">
            <a class="btn secondary" href="/hr/departments">Department Review</a>
            <a class="btn secondary" href="/hr/reports">Reports</a>
            <a class="btn secondary" href="/hr/admin-accounts">Admin Accounts</a>
            <a class="btn secondary" href="/hr/periods">Period and Slot Settings</a>
            <form action="/hr/logout" method="post">
              <button class="btn secondary" type="submit">Logout</button>
            </form>
          </div>
        </div>

        <div class="stats compact">
          <div>
            <strong><%= stats.total %></strong>
            <span>Total</span>
          </div>
          <div>
            <strong><%= stats.verified %></strong>
            <span>Verified</span>
          </div>
          <div>
            <strong><%= stats.approved %></strong>
            <span>Admitted</span>
          </div>
          <div>
            <strong><%= stats.rejected %></strong>
            <span>Rejected</span>
          </div>
        </div>

        <form method="get" action="/hr/applications" class="filter-row">
          <label>
            Filter by status
            <select name="status">
              <option value="Verified" <%= statusFilter === 'Verified' ? 'selected' : '' %>>Verified</option>
              <option value="Admitted" <%= statusFilter === 'Admitted' ? 'selected' : '' %>>Admitted</option>
              <option value="Rejected" <%= statusFilter === 'Rejected' ? 'selected' : '' %>>Rejected</option>
              <option value="All" <%= statusFilter === 'All' ? 'selected' : '' %>>All</option>
            </select>
          </label>
          <label>
            Filter by department
            <select name="department">
              <option value="All" <%= departmentFilter === 'All' ? 'selected' : '' %>>All departments</option>
              <% departmentOptions.forEach((department) => { %>
                <option value="<%= department.key %>" <%= departmentFilter === department.key ? 'selected' : '' %>>
                  <%= department.label %>
                </option>
              <% }) %>
            </select>
          </label>
          <button class="btn" type="submit">Apply Filter</button>
        </form>
        <p class="muted-note">Only department-verified applications enter this HR queue.</p>

        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th class="table-number-cell">ID</th>
                <th>Tracking Number</th>
                <th>Name</th>
                <th>Email</th>
                <th>Department</th>
                <th>Period</th>
                <th class="table-status-cell">Status</th>
                <th class="table-date-cell">Submitted</th>
                <th class="table-action-cell">Action</th>
              </tr>
            </thead>
            <tbody>
              <% if (!applications.length) { %>
                <tr>
                  <td class="table-empty-state" colspan="9"><strong>No applications found.</strong> Adjust the selected filter and try again.</td>
                </tr>
              <% } %>

              <% applications.forEach((application) => { %>
                <tr>
                  <td class="table-number-cell"><%= application.id %></td>
                  <td><%= application.placementNumber || application.id %></td>
                  <td><%= application.fullName %></td>
                  <td><%= application.email %></td>
                  <td><%= application.appliedDepartment ? getDepartmentLabel(application.appliedDepartment) : 'Not set' %></td>
                  <td><%= application.period ? getPeriodLabel(application.period) : 'Not set' %></td>
                  <td class="table-status-cell"><span class="badge <%= getStatusClass(application.status) %>"><%= application.status %></span></td>
                  <td class="table-date-cell"><%= formatDate(application.submittedAt) %></td>
                  <td class="table-action-cell"><a href="/hr/applications/<%= application.id %>">Review</a></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <h2>Department Review Access</h2>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Department</th>
                <th class="table-count-cell">Capacity</th>
                <th class="table-count-cell">Applications</th>
                <th class="table-count-cell">Verified</th>
                <th class="table-count-cell">Admitted</th>
                <th class="table-count-cell">Pending</th>
                <th class="table-count-cell">Remaining</th>
                <th class="table-action-cell">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% departmentSummaries.forEach((department) => { %>
                <tr>
                  <td>
                    <a href="/hr/departments/<%= department.key %>/open"><%= department.label %></a>
                  </td>
                  <td class="table-count-cell"><%= department.capacity %></td>
                  <td class="table-count-cell"><%= department.applications %></td>
                  <td class="table-count-cell"><%= department.verified %></td>
                  <td class="table-count-cell"><%= department.approved %></td>
                  <td class="table-count-cell"><%= department.pending %></td>
                  <td class="table-count-cell"><%= department.remaining %></td>
                  <td class="table-action-cell">
                    <div class="table-actions">
                      <a href="/hr/departments/<%= department.key %>/open">Review</a>
                      <a href="/hr/reports/export.csv?status=All&period=All&department=<%= department.key %>">Export</a>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>
    </main>
<%- include("partials/layout-close") %>


<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Application Status</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main class="container">
      <section class="card">
        <h1>Application Received</h1>
        <p>Your application has been submitted successfully.</p>

        <div class="summary">
          <p><strong>Application ID:</strong> <%= application.id %></p>
          <p><strong>Name:</strong> <%= application.fullName %></p>
          <p><strong>Status:</strong> <span class="badge <%= application.status.toLowerCase() %>"><%= application.status %></span></p>
          <p><strong>Submitted:</strong> <%= formatDate(application.submittedAt) %></p>
          <p><strong>Last Updated:</strong> <%= formatDate(application.updatedAt) %></p>
          <p><strong>Reviewer Comment:</strong> <%= application.reviewerComment || 'No comment yet.' %></p>
        </div>

        <div class="actions">
          <a class="btn" href="/apply">Submit Another Application</a>
          <a class="btn secondary" href="/">Back to Home</a>
        </div>
      </section>
    </main>
  </body>
</html>

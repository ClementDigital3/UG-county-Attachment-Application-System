<%- include("partials/layout-open", { pageTitle: "Application Status", activePortal: "student" }) %>
<main class="container">
      <section class="card">
        <h1>Application Received</h1>
        <p>Your application has been submitted successfully.</p>

        <div class="notice">
          Check your email for the application notification and next-step guidance. If email or SMS delivery delays, keep your tracking number and use the student dashboard to follow progress.
        </div>

        <div class="summary">
          <p><strong>Tracking Number:</strong> <%= application.placementNumber || application.id %></p>
          <p><strong>Name:</strong> <%= application.fullName %></p>
          <p><strong>Applied Department:</strong> <%= application.appliedDepartment ? getDepartmentLabel(application.appliedDepartment) : 'Not set' %></p>
          <p><strong>Assigned Department:</strong> <%= application.assignedDepartment ? getDepartmentLabel(application.assignedDepartment) : 'Not assigned yet' %></p>
          <p><strong>Period:</strong> <%= application.period ? getPeriodLabel(application.period) : 'Not set' %></p>
          <p><strong>Status:</strong> <span class="badge <%= getStatusClass(application.status) %>"><%= application.status %></span></p>
          <p><strong>Submitted:</strong> <%= formatDate(application.submittedAt) %></p>
          <p><strong>Terms Accepted:</strong> <%= application.termsAcceptance && application.termsAcceptance.agreed ? `Yes - ${formatDate(application.termsAcceptance.agreedAt)}` : 'Not recorded' %></p>
          <p><strong>Last Updated:</strong> <%= formatDate(application.updatedAt) %></p>
          <p><strong>Reviewer Comment:</strong> <%= application.reviewerComment || 'No comment yet.' %></p>
          <p><strong>Next Step:</strong> Your application is received. Department review comes first, then HR handles the NITA workflow before the final admission decision.</p>
          <p><strong>NITA Workflow:</strong> Track the county-endorsed NITA form, download it when it appears in the dashboard, return the stamped copy, and later download your joining letter from the student dashboard.</p>
        </div>

        <div class="actions">
          <a class="btn" href="/track?idNumber=<%= encodeURIComponent(application.idNumber || '') %>&email=<%= encodeURIComponent(application.email) %>">Open Student Dashboard</a>
          <a class="btn" href="/apply">Submit Another Application</a>
          <a class="btn secondary" href="/">Back to Home</a>
        </div>
      </section>
    </main>
<%- include("partials/layout-close") %>


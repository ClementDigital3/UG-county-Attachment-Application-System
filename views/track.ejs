<%- include("partials/layout-open", { pageTitle: "Track Application", activePortal: "student" }) %>
<main class="container small">
      <section class="card">
        <h1>Track Application Status</h1>
        <p>Enter your tracking/placement number (or application ID) and email used during submission.</p>

        <% if (error) { %>
          <div class="alert"><%= error %></div>
        <% } %>

        <% if (message) { %>
          <div class="notice"><%= message %></div>
        <% } %>

        <form action="/track" method="post" class="form-grid">
          <label class="full-width">
            Tracking / Placement Number
            <input type="text" name="trackingNumber" placeholder="UG-ATT-2026-123456 or ATT-..." required />
          </label>

          <label class="full-width">
            Email
            <input type="email" name="email" required />
          </label>

          <div class="actions full-width">
            <button class="btn" type="submit">Check Status</button>
            <a class="btn secondary" href="/">Back</a>
          </div>
        </form>

        <% if (result) { %>
          <hr />
          <div class="summary">
            <p><strong>Tracking / Placement Number:</strong> <%= result.placementNumber || result.id %></p>
            <p><strong>Application ID:</strong> <%= result.id %></p>
            <p><strong>Name:</strong> <%= result.fullName %></p>
            <p><strong>Applied Department:</strong> <%= result.appliedDepartment ? getDepartmentLabel(result.appliedDepartment) : 'Not set' %></p>
            <p><strong>Assigned Department:</strong> <%= result.assignedDepartment ? getDepartmentLabel(result.assignedDepartment) : 'Not assigned yet' %></p>
            <p><strong>Period:</strong> <%= result.period ? getPeriodLabel(result.period) : 'Not set' %></p>
            <p><strong>Status:</strong> <span class="badge <%= getStatusClass(result.status) %>"><%= result.status %></span></p>
            <p><strong>Submitted:</strong> <%= formatDate(result.submittedAt) %></p>
            <p><strong>Last Updated:</strong> <%= formatDate(result.updatedAt) %></p>
            <p><strong>Reviewer Comment:</strong> <%= result.reviewerComment || 'No comment yet.' %></p>
          </div>

          <% if (result.joiningLetter && result.joiningLetter.filename) { %>
            <div class="actions">
              <a class="btn" href="/application/<%= result.id %>/joining-letter?email=<%= encodeURIComponent(result.email) %>">
                Download Joining Letter
              </a>
            </div>
          <% } %>

          <% if (rejectedDocuments.length) { %>
            <h2>Documents To Re-Upload</h2>
            <p>Admin has marked the following documents as incorrect. Re-upload all listed documents.</p>

            <ul>
              <% rejectedDocuments.forEach((document) => { %>
                <li>
                  <strong><%= document.label %></strong>
                  <% if (document.review.comment) { %>
                    - <%= document.review.comment %>
                  <% } %>
                </li>
              <% }) %>
            </ul>

            <form action="/track/resubmit" method="post" enctype="multipart/form-data" class="form-grid">
              <input type="hidden" name="trackingNumber" value="<%= result.placementNumber || result.id %>" />
              <input type="hidden" name="email" value="<%= result.email %>" />

              <% rejectedDocuments.forEach((document) => { %>
                <label class="full-width">
                  <%= document.label %> *
                  <% if (document.key === 'passportPhoto') { %>
                    <span class="field-hint">Any clear image size is allowed.</span>
                  <% } %>
                  <input type="file" name="<%= document.key %>" accept="<%= document.accept %>" required />
                </label>
              <% }) %>

              <div class="actions full-width">
                <button class="btn" type="submit">Submit Corrected Documents</button>
              </div>
            </form>
          <% } %>
        <% } %>
      </section>
    </main>
<%- include("partials/layout-close") %>


<%- include("partials/layout-open", { pageTitle: "Track Application", activePortal: "student" }) %>
<main class="container <%= result ? 'wide' : 'small' %>">
      <section class="card">
        <h1>Track Application Status</h1>
        <p>Enter the ID number used during application and the same email address to open your student dashboard.</p>

        <% if (error) { %>
          <div class="alert"><%= error %></div>
        <% } %>

        <% if (message) { %>
          <div class="notice"><%= message %></div>
        <% } %>

        <form action="/track" method="post" class="form-grid <%= result ? '' : 'auth-form' %>">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <label class="full-width">
            ID Number
            <input
              type="text"
              name="idNumber"
              placeholder="12345678"
              value="<%= formData.idNumber || '' %>"
              required
            />
          </label>

          <label class="full-width">
            Email
            <input type="email" name="email" value="<%= formData.email || '' %>" required />
          </label>

          <div class="actions full-width">
            <button class="btn" type="submit">Open Dashboard</button>
            <a class="btn secondary" href="/verify">Public Verification</a>
            <a class="btn secondary" href="/">Back</a>
          </div>
        </form>
      </section>

      <% if (result && studentDashboard) { %>
        <section class="card student-dashboard-hero">
          <div class="row-between">
            <div>
              <p class="eyebrow">Student Self-Service Dashboard</p>
              <h2><%= studentDashboard.status.heading %></h2>
              <p><%= studentDashboard.status.summary %></p>
            </div>
            <div class="dashboard-badge-wrap">
              <span class="badge <%= getStatusClass(result.status) %>"><%= result.status %></span>
            </div>
          </div>

          <div class="dashboard-quick-grid">
            <div class="summary">
              <p><strong>Tracking Number:</strong> <%= result.placementNumber || result.id %></p>
              <p><strong>Name:</strong> <%= result.fullName %></p>
              <p><strong>Email:</strong> <%= result.email %></p>
            </div>
            <div class="summary">
              <p><strong>Next Action:</strong> <%= studentDashboard.status.nextActionTitle %></p>
              <p><%= studentDashboard.status.nextActionText %></p>
              <p><strong>Notifications:</strong> Check your email for workflow updates and keep using this dashboard for live tracking.</p>
              <div class="actions tight">
                <a class="btn secondary" href="/apply">Submit Another Application</a>
              </div>
            </div>
          </div>
        </section>

        <section class="dashboard-grid">
          <article class="card">
            <h2>Application Overview</h2>
            <div class="stats compact dashboard-stat-grid">
              <div>
                <strong><%= result.appliedDepartment ? getDepartmentLabel(result.appliedDepartment) : 'Not set' %></strong>
                <span>Applied Department</span>
              </div>
              <div>
                <strong><%= result.assignedDepartment ? getDepartmentLabel(result.assignedDepartment) : 'Pending' %></strong>
                <span>Assigned Department</span>
              </div>
              <div>
                <strong><%= result.period ? getPeriodLabel(result.period) : 'Not set' %></strong>
                <span>Attachment Period</span>
              </div>
              <div>
                <strong><%= formatDate(result.submittedAt) %></strong>
                <span>Submitted</span>
              </div>
              <div>
                <strong><%= formatDate(result.updatedAt) %></strong>
                <span>Last Updated</span>
              </div>
              <div>
                <strong><%= result.course %></strong>
                <span>Course / Program</span>
              </div>
              <div>
                <strong><%= getCourseLevelLabel(result.courseLevel) %></strong>
                <span>Course Level</span>
              </div>
            </div>
          </article>

          <article class="card">
            <h2>Progress Timeline</h2>
            <div class="timeline-list">
              <% studentDashboard.timeline.forEach((step) => { %>
                <div class="timeline-step is-<%= step.state %>">
                  <div class="timeline-marker"></div>
                  <div class="timeline-content">
                    <div class="row-between timeline-heading-row">
                      <strong><%= step.label %></strong>
                      <span class="timeline-state"><%= step.state === 'current' ? 'Current' : step.state === 'complete' ? 'Done' : 'Upcoming' %></span>
                    </div>
                    <p><%= step.note %></p>
                    <% if (step.date) { %>
                      <p class="muted-note">Updated: <%= formatDate(step.date) %></p>
                    <% } %>
                  </div>
                </div>
              <% }) %>
            </div>
          </article>

          <article class="card">
            <h2>Reviewer Feedback</h2>
            <div class="summary">
              <p><strong>Department / HR Comment:</strong></p>
              <p><%= result.reviewerComment || 'No reviewer comment yet.' %></p>
            </div>
            <div class="summary">
              <p><strong>Your Cover Note:</strong></p>
              <p><%= result.coverNote || 'No cover note saved.' %></p>
            </div>
          </article>

          <article class="card">
            <h2>NITA Workflow</h2>
            <div class="summary">
              <p><strong>Initial NITA document:</strong>
                <%= result.nitaDocument && result.nitaDocument.filename ? 'Submitted' : 'Not uploaded' %>
              </p>
              <p><strong>County-endorsed NITA document:</strong>
                <%= result.countySignedNitaDocument && result.countySignedNitaDocument.filename ? 'Ready to download' : 'Not available yet' %>
              </p>
              <p><strong>Stamped NITA re-submission:</strong>
                <%= result.nitaResubmittedDocument && result.nitaResubmittedDocument.filename ? 'Submitted to HR' : 'Not submitted yet' %>
              </p>
              <p><strong>NITA re-submission marker:</strong>
                <%= result.nitaWorkflow.studentResubmissionCount > 0 ? `Already returned to HR on ${formatDate(result.nitaWorkflow.studentResubmittedAt)}` : 'Awaiting your stamped NITA re-upload' %>
              </p>
              <p><strong>NITA workflow status:</strong> <%= result.nitaWorkflow.status %></p>
              <p><strong>Workflow note:</strong> <%= result.nitaWorkflow.comment || 'No NITA workflow note yet.' %></p>
            </div>

            <% if (result.countySignedNitaDocument && result.countySignedNitaDocument.filename) { %>
              <div class="actions tight">
                <a class="btn secondary" href="/application/<%= result.id %>/county-signed-nita?email=<%= encodeURIComponent(result.email) %>">
                  Download County-Endorsed NITA
                </a>
              </div>
            <% } %>

            <% if (result.nitaWorkflow.status === 'Awaiting Student NITA Resubmission' && result.countySignedNitaDocument && result.countySignedNitaDocument.filename) { %>
              <form action="/track/nita-resubmit" method="post" enctype="multipart/form-data" class="form-grid">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <input type="hidden" name="idNumber" value="<%= result.idNumber || '' %>" />
                <input type="hidden" name="email" value="<%= result.email %>" />

                <label class="full-width">
                  <%= nitaResubmissionDefinition.label %> *
                  <span class="field-hint">
                    Upload the same county-endorsed NITA document as a PDF after it has been stamped at the NITA office.
                  </span>
                  <input type="file" name="<%= nitaResubmissionDefinition.key %>" accept="<%= nitaResubmissionDefinition.accept %>" required />
                  <button type="button" class="btn secondary use-test-nita-btn" data-target-name="<%= nitaResubmissionDefinition.key %>" style="margin-top: 0.5rem; padding: 0.35rem 0.7rem; font-size: 0.78rem; display: inline-flex; align-items: center; gap: 0.3rem; border-radius: 8px; font-weight: 600; width: fit-content; cursor: pointer;">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="vertical-align: middle;">
                      <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                      <polyline points="7 10 12 15 17 10"></polyline>
                      <line x1="12" y1="15" x2="12" y2="3"></line>
                    </svg>
                    <span>Use Default Test NITA Form</span>
                  </button>
                </label>

                <div class="actions full-width">
                  <button class="btn" type="submit">Submit Stamped NITA Document</button>
                </div>
              </form>
            <% } %>
          </article>

          <article class="card">
            <h2>Documents And Letter</h2>
            <div class="summary">
              <p><strong>Submitted combined document:</strong>
                <%= result.combinedDocument && result.combinedDocument.filename ? 'Available' : 'Not found' %>
              </p>
              <p><strong>Submitted NITA document:</strong>
                <%= result.nitaDocument && result.nitaDocument.filename ? 'Available' : 'Not found' %>
              </p>
              <p><strong>Joining letter:</strong>
                <%= result.joiningLetter && result.joiningLetter.filename ? 'Ready to download' : 'Not available yet' %>
              </p>
              <% if (result.joiningLetter && result.joiningLetter.filename) { %>
                <div class="actions tight">
                  <a class="btn" href="/application/<%= result.id %>/joining-letter?email=<%= encodeURIComponent(result.email) %>">
                    Download Joining Letter
                  </a>
                </div>
              <% } %>
            </div>
          </article>
        </section>

        <% if (rejectedDocuments.length) { %>
          <section class="card">
            <h2>Correction Tasks</h2>
            <p>Department review marked the following documents as incorrect. Re-upload all listed documents to move the application forward.</p>

            <div class="task-list">
              <% rejectedDocuments.forEach((document) => { %>
                <div class="summary">
                  <p><strong><%= document.label %></strong></p>
                  <p><%= getReviewExplanation(document.review) %></p>
                </div>
              <% }) %>
            </div>

            <form action="/track/resubmit" method="post" enctype="multipart/form-data" class="form-grid">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <input type="hidden" name="idNumber" value="<%= result.idNumber || '' %>" />
              <input type="hidden" name="email" value="<%= result.email %>" />

              <% rejectedDocuments.forEach((document) => { %>
                <label class="full-width">
                  <%= document.label %> *
                  <span class="field-hint">
                    <%= document.key === nitaResubmissionDefinition.key || document.key === 'nitaDocument' ? 'Upload the corrected document as a PDF.' : 'Upload the corrected document as a PDF or DOCX file.' %>
                  </span>
                  <input type="file" name="<%= document.key %>" accept="<%= document.accept %>" required />
                  <% if (document.key === nitaResubmissionDefinition.key || document.key === 'nitaDocument') { %>
                    <button type="button" class="btn secondary use-test-nita-btn" data-target-name="<%= document.key %>" style="margin-top: 0.5rem; padding: 0.35rem 0.7rem; font-size: 0.78rem; display: inline-flex; align-items: center; gap: 0.3rem; border-radius: 8px; font-weight: 600; width: fit-content; cursor: pointer;">
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="vertical-align: middle;">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                        <polyline points="7 10 12 15 17 10"></polyline>
                        <line x1="12" y1="15" x2="12" y2="3"></line>
                      </svg>
                      <span>Use Default Test NITA Form</span>
                    </button>
                  <% } %>
                </label>
              <% }) %>

              <div class="actions full-width">
                <button class="btn" type="submit">Submit Corrected Documents</button>
              </div>
            </form>
          </section>
        <% } %>
      <% } %>
    </main>

    <script>
      (() => {
        document.addEventListener("click", async (e) => {
          const btn = e.target.closest(".use-test-nita-btn");
          if (!btn) return;
          
          const targetName = btn.dataset.targetName;
          const fileInput = document.querySelector(`input[type="file"][name="${targetName}"]`);
          if (!fileInput) return;

          const originalText = btn.innerHTML;
          btn.disabled = true;
          btn.innerHTML = `
            <span class="loading-spinner" style="margin-right: 0.2rem; vertical-align: middle;"></span>
            <span>Loading template...</span>
          `;

          try {
            const response = await fetch("/testing-nita-template.pdf");
            if (!response.ok) throw new Error("Failed to fetch template");
            const blob = await response.blob();
            const file = new File([blob], "testing-nita-template.pdf", { type: "application/pdf" });
            
            const dataTransfer = new DataTransfer();
            dataTransfer.items.add(file);
            fileInput.files = dataTransfer.files;

            fileInput.dispatchEvent(new Event("change", { bubbles: true }));

            btn.style.background = "var(--success)";
            btn.style.color = "#ffffff";
            btn.innerHTML = `
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 0.2rem; vertical-align: middle;">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>Test NITA Loaded!</span>
            `;
          } catch (err) {
            console.error(err);
            btn.style.background = "var(--danger)";
            btn.style.color = "#ffffff";
            btn.innerHTML = `<span>Error loading template</span>`;
            setTimeout(() => {
              btn.disabled = false;
              btn.style.background = "";
              btn.style.color = "";
              btn.innerHTML = originalText;
            }, 2000);
          }
        });
      })();
    </script>
<%- include("partials/layout-close") %>

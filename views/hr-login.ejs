<%- include("partials/layout-open", { pageTitle: "HR Portal Login", activePortal: "hr" }) %>
<main class="container small">
      <section class="card">
        <h1>HR Portal</h1>
        <p>
          This portal is for authorized County HR officers and designated records staff handling
          attachment intake, department review control, and the final HR admission decision.
        </p>
        <div class="summary">
          <p><strong>Access:</strong> Authorized County HR personnel only.</p>
          <p><strong>Sign in:</strong> Use the HR login credentials already issued for this system.</p>
        </div>

        <% if (error) { %>
          <div class="alert"><%= error %></div>
        <% } %>

        <form action="<%= hrPortalPath %>" method="post" class="form-grid auth-form">
          <label>
            Username
            <input type="text" name="username" required />
          </label>

          <label>
            Password
            <input type="password" name="password" required />
          </label>

          <div class="actions">
            <button class="btn" type="submit">Login</button>
            <a class="btn secondary" href="/">Back</a>
          </div>
        </form>
      </section>
    </main>
<%- include("partials/layout-close") %>


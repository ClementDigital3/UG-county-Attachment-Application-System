<%- include("partials/layout-open", { pageTitle: "Department Access Records", activePortal: "hr" }) %>
<main class="container wide">
      <section class="card">
        <div class="row-between">
          <h1>Department Access Records</h1>
          <div class="actions tight">
            <a class="btn secondary" href="/hr/departments">Department Review</a>
            <a class="btn secondary" href="/hr/reports">Reports</a>
            <a class="btn secondary" href="/hr/periods">Period and Slot Settings</a>
            <a class="btn secondary" href="/hr/applications">HR Queue</a>
            <form action="/hr/logout" method="post">
              <button class="btn secondary" type="submit">Logout</button>
            </form>
          </div>
        </div>

        <p>
          HR controls all department review access. These department records remain under HR management
          and no longer use independent portal logins.
        </p>

        <% if (notice) { %>
          <div class="notice"><%= notice %></div>
        <% } %>

        <% if (error) { %>
          <div class="alert"><%= error %></div>
        <% } %>

        <div class="summary">
          <p><strong>Total department records:</strong> <%= adminAccounts.length %></p>
          <p><strong>Active records:</strong> <%= adminAccounts.filter((item) => item.isActive).length %></p>
          <p><strong>Frozen records:</strong> <%= adminAccounts.filter((item) => !item.isActive).length %></p>
        </div>
      </section>

      <section class="card">
        <h2>Create Department Record</h2>
        <form action="/hr/admin-accounts/create" method="post" class="form-grid">
          <label>
            Record Code
            <input type="text" name="username" placeholder="ict_admin" required />
          </label>

          <label>
            Display Name
            <input type="text" name="displayName" placeholder="ICT Department Officer" required />
          </label>

          <label class="full-width">
            Department
            <select name="department" required>
              <option value="">Select department</option>
              <% departmentOptions.forEach((department) => { %>
                <option value="<%= department.key %>"><%= department.label %></option>
              <% }) %>
            </select>
          </label>

          <div class="actions full-width">
            <button class="btn" type="submit">Create Department Record</button>
          </div>
        </form>
      </section>

      <section class="card">
        <h2>Existing Department Records</h2>

        <% if (!adminAccounts.length) { %>
          <p>No department records found.</p>
        <% } %>

        <div class="admin-account-grid">
          <% adminAccounts.forEach((account) => { %>
            <article class="summary admin-account-card">
              <div class="row-between">
                <div>
                  <h3><%= account.displayName %></h3>
                  <p class="muted-note">
                    <strong><%= account.username %></strong> ·
                    <%= getDepartmentLabel(account.department) %>
                  </p>
                </div>
                <span class="badge <%= account.isActive ? 'approved' : 'rejected' %>">
                  <%= account.isActive ? 'Active' : 'Frozen' %>
                </span>
              </div>

              <form action="/hr/admin-accounts/<%= account.username %>/update" method="post" class="form-grid">
                <label>
                  Record Code
                  <input type="text" name="username" value="<%= account.username %>" required />
                </label>

                <label>
                  Display Name
                  <input type="text" name="displayName" value="<%= account.displayName %>" required />
                </label>

                <label class="full-width">
                  Department
                  <select name="department" required>
                    <% departmentOptions.forEach((department) => { %>
                      <option value="<%= department.key %>" <%= account.department === department.key ? 'selected' : '' %>>
                        <%= department.label %>
                      </option>
                    <% }) %>
                  </select>
                </label>

                <div class="actions full-width">
                  <button class="btn" type="submit">Save Record Details</button>
                  <a class="btn secondary" href="/hr/departments/<%= account.department %>/open">Open Department Review</a>
                </div>
              </form>

              <div class="actions">
                <form action="/hr/admin-accounts/<%= account.username %>/toggle" method="post">
                  <input type="hidden" name="isActive" value="<%= account.isActive ? '0' : '1' %>" />
                  <button class="btn secondary" type="submit">
                    <%= account.isActive ? 'Freeze Record' : 'Restore Record' %>
                  </button>
                </form>
              </div>

              <p class="muted-note">
                Created: <%= account.createdAt ? formatDate(account.createdAt) : 'Not recorded' %><br />
                Updated: <%= account.updatedAt ? formatDate(account.updatedAt) : 'Not recorded' %>
              </p>
            </article>
          <% }) %>
        </div>
      </section>
    </main>
<%- include("partials/layout-close") %>

PORT=3000
SESSION_SECRET=replace-with-a-long-random-secret
SESSION_COOKIE_MAX_AGE_HOURS=12

# Optional storage root for deployments with persistent disks.
# Leave empty for local development. On Render use: /var/data for uploaded files.
STORAGE_ROOT=

# MongoDB connection settings
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=attachment_application_system

# File storage provider:
# - local: keep uploaded files on the server filesystem
# - cloudinary: store uploaded files in Cloudinary
FILE_STORAGE_PROVIDER=local

# Cloudinary settings used only when FILE_STORAGE_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=attachment-application-system

# County NITA Part C auto-fill defaults
COUNTY_ATTACHMENT_PROVIDER_NAME=County Government of Uasin Gishu
COUNTY_ATTACHMENT_PROVIDER_POSTAL_ADDRESS=P.O. Box 40
COUNTY_ATTACHMENT_PROVIDER_POSTAL_CODE=30100
COUNTY_ATTACHMENT_PROVIDER_TOWN=Eldoret
COUNTY_ATTACHMENT_PROVIDER_PHYSICAL_ADDRESS=County Headquarters
COUNTY_ATTACHMENT_PROVIDER_REGION=Uasin Gishu
COUNTY_ATTACHMENT_PROVIDER_TELEPHONE=05320160000
COUNTY_ATTACHMENT_PROVIDER_EMAIL=info@uasingishu.go.ke
COUNTY_ATTACHMENT_PROVIDER_FAX=N/A
COUNTY_ATTACHMENT_OFFICER_IN_CHARGE=Director, Human Resource Management
COUNTY_ATTACHMENT_OFFICER_TELEPHONE=05320160000
COUNTY_ATTACHMENT_SIGNATORY_NAME=Director, Human Resource Management
COUNTY_ATTACHMENT_SIGNATORY_DESIGNATION=Authorized County HR Signatory

# Portal entry paths
# ADMIN_PORTAL_PATH remains as a compatibility redirect to the HR portal.
ADMIN_PORTAL_PATH=/staff-portal
HR_PORTAL_PATH=/hr-portal

# Display timezone for timestamps shown in the portal
DISPLAY_TIMEZONE=Africa/Nairobi

# HR portal credentials
HR_USERNAME=hr_admin
HR_PASSWORD=change_hr_password

# Optional presentation mode:
# If set, the same credentials can log in to the legacy staff redirect and the HR portal.
PRESENTATION_LOGIN_USERNAME=
PRESENTATION_LOGIN_PASSWORD=

# Department admin bootstrap password used only when the database is first created
DEFAULT_DEPARTMENT_ADMIN_PASSWORD=change_me

# Demo/testing mode: true allows broad test uploads; set false for production
ALLOW_ANY_TEST_UPLOADS=false

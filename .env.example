PORT=3000
SESSION_SECRET=replace-with-a-long-random-secret

# Optional storage root for deployments with persistent disks.
# Leave empty for local development. On Render use: /var/data
STORAGE_ROOT=

# Portal entry paths
ADMIN_PORTAL_PATH=/staff-portal
HR_PORTAL_PATH=/hr-portal

# HR portal credentials
HR_USERNAME=hr_admin
HR_PASSWORD=change_hr_password

# Optional presentation mode:
# If set, the same credentials can log in to both Admin and HR portals.
PRESENTATION_LOGIN_USERNAME=
PRESENTATION_LOGIN_PASSWORD=

# Department staff accounts are managed in data/department-admins.json
# (default username pattern: <department>_admin)
# Department admin bootstrap password used only when data/department-admins.json is first created
DEFAULT_DEPARTMENT_ADMIN_PASSWORD=change_me

# Demo/testing mode: true allows broad test uploads; set false for production
ALLOW_ANY_TEST_UPLOADS=false
